---
import { SHADOW_MAP_CROSS_LINK } from "@/data/knowledge";

const { title, description, href } = SHADOW_MAP_CROSS_LINK;
---

<aside class="shadow-map-teaser border-border bg-muted/30 border p-5 sm:p-6">
  <p class="text-muted-foreground text-xs font-semibold uppercase tracking-[0.18em]">
    Для складніших систем
  </p>
  <h2 class="mt-3 text-xl font-semibold">{title}</h2>
  <p class="mt-3 text-sm leading-7 text-muted-foreground">{description}</p>
  <a
    href={href}
    class="text-accent mt-4 inline-block text-sm font-medium underline decoration-dashed underline-offset-4"
  >
    Перейти до проєкту
  </a>
</aside>
