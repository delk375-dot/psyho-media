---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { SERVICE_CTA } from "@/data/knowledge";
import { CATEGORIES } from "@/data/categories";
import config from "@/config";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;

const posts = await getCollection("posts", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
const latestPosts = sortedPosts.slice(0, postsConfig.perIndex);
const homePath = getRelativeLocaleUrl(locale, "");

const painfulQuestions = [
  "Чому мене ігнорують?",
  "Чому люди зникають без пояснення?",
  "Чому хороших не хочуть?",
  "Чому після близькості стає холодно?",
  "Чому люди ревнують?",
  "Чому гроші викликають сором?",
  "Як зрозуміти маніпулятора?",
  "Чому токсичні люди здаються сильними?",
];
---

<Layout
  title="Людський механізм — психологія стосунків, грошей, сексу і маніпуляцій"
  description="Масове психологічне медіа про стосунки, ревнощі, зради, маніпуляції, токсичних людей, гроші, секс, конфлікти і приховані мотиви поведінки."
>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="relative overflow-hidden border-border border-b pt-16 pb-14 sm:pt-24 sm:pb-20">
      <div class="relative z-10 grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,0.72fr)] lg:items-center">
        <div class="max-w-3xl">
          <p class="text-muted-foreground text-sm leading-6 uppercase tracking-[0.22em]">
            Психологія повсякденних драм
          </p>

          <h1 class="mt-7 text-5xl leading-[1.05] font-semibold tracking-normal sm:text-7xl">
            Людський механізм
          </h1>

          <p class="mt-8 max-w-2xl text-lg leading-8 text-muted-foreground sm:text-xl sm:leading-9">
            Медіа про те, чому люди зникають, ревнують, маніпулюють, мовчать,
            закохуються не в тих, бояться грошей, втрачають бажання і воюють за
            любов, статус та контроль.
          </p>

          <div class="mt-10 flex flex-wrap gap-3 sm:mt-12">
            <LinkButton
              href={getRelativeLocaleUrl(locale, "topics")}
              class="bg-accent text-accent-foreground px-5 py-3 hover:opacity-90"
            >
              Читати розбори
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
            <LinkButton
              href={getRelativeLocaleUrl(locale, "categories")}
              class="border-border border px-5 py-3 hover:text-accent"
            >
              Карта тем
            </LinkButton>
          </div>
        </div>

        <div class="human-hero-mark hidden lg:block" aria-hidden="true">
          <span class="human-hero-heart">М</span>
          <span class="human-hero-line"></span>
          <span class="human-hero-note">без відповіді</span>
        </div>
      </div>
    </section>

    <section id="topic-map" class="border-border border-b py-16 sm:py-24">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-semibold tracking-normal">Карта тем</h2>
        <p class="mt-4 text-base leading-8 text-muted-foreground">
          Головні напрямки медіа: від стосунків і зрад до грошей, сексу,
          токсичних людей, родинних сценаріїв і мовчання без пояснення.
        </p>
      </div>

      <div class="mt-10">
        <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {CATEGORIES.map(category => (
            <li class="map-card border-border bg-muted/20 border p-5 sm:p-6">
              <a
                href={getRelativeLocaleUrl(locale, `categories/${category.slug}`)}
                class="group block min-h-full"
              >
                <span class="topic-sigil" aria-hidden="true"></span>
                <h4 class="mt-4 text-lg font-semibold group-hover:text-accent">
                  {category.title}
                </h4>
                <p class="mt-3 text-sm leading-7 text-muted-foreground">
                  {category.description}
                </p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="latest-research" class="border-border border-b py-16 sm:py-24">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-semibold tracking-normal">Нові розбори</h2>
      </div>

      {
        latestPosts.length > 0 ? (
          <ul class="mt-6">
            {latestPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        ) : (
          <p class="mt-4 text-muted-foreground">
            Редакція готує перші розбори.
          </p>
        )
      }

      <div class="mt-10">
        <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
          Переглянути всі статті
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </section>

    <section id="painful-questions" class="border-border border-b py-16 sm:py-24">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-semibold tracking-normal">Найболючіші питання</h2>
        <p class="mt-4 text-base leading-8 text-muted-foreground">
          Запити, з яких починається не академічна психологія, а реальна потреба
          зрозуміти, що з людиною, стосунками або грошима відбувається насправді.
        </p>
      </div>

      <ul class="mt-8 grid gap-3 sm:grid-cols-2">
        {painfulQuestions.map(question => (
          <li class="border-border bg-muted/20 border px-4 py-3 text-base font-medium">
            {question}
          </li>
        ))}
      </ul>
    </section>

    <section id="services" class="border-border border-b py-16 sm:py-24">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-semibold tracking-normal">Практичні формати</h2>
        <p class="mt-4 text-base leading-8 text-muted-foreground">
          Плейсхолдери для майбутніх продуктів, які можна м'яко підключати до
          статей без агресивної реклами і без зміни архітектури AstroPaper.
        </p>
      </div>
      <ul class="mt-8 grid gap-5 sm:grid-cols-2">
        {SERVICE_CTA.map(service => (
          <li class="map-card border-border bg-muted/20 border p-5 sm:p-6">
            <span class="topic-sigil" aria-hidden="true"></span>
            <h3 class="mt-4 text-lg font-semibold">{service.title}</h3>
            <p class="mt-3 text-sm leading-7 text-muted-foreground">
              {service.description}
            </p>
          </li>
        ))}
      </ul>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
