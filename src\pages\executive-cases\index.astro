---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { EXECUTIVE_CASES } from "@/data/knowledge";
import config from "@/config";
---

<Layout
  title={`Кейси для керівників | ${config.site.title}`}
  description="Плейсхолдери кейсів для майбутніх практичних розборів влади, переговорів, комунікації і конфліктів."
>
  <Header />
  <Breadcrumb />
  <Main pageTitle="Кейси для керівників" pageDesc="Формат майбутніх кейсів: ситуація, системна діагностика, психологічні ризики, рішення і питання для керівника.">
    <ul class="grid gap-4 sm:grid-cols-2">
      {EXECUTIVE_CASES.map(item => (
        <li class="border-border bg-muted/30 border p-4">
          <h2 class="text-xl font-semibold">{item.title}</h2>
          <p class="mt-2 text-muted-foreground">{item.description}</p>
        </li>
      ))}
    </ul>
  </Main>
  <Footer />
</Layout>
