---
import { getRelativeLocaleUrl } from "astro:i18n";
import { CATEGORIES } from "@/data/categories";
import { TOPIC_HUBS } from "@/data/knowledge";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
---

<nav class="knowledge-map-shell border-border bg-muted/20 border p-5 sm:p-6" aria-label="Карта тем">
  <div class="grid gap-8 lg:grid-cols-[1fr_1fr]">
    <section>
      <div class="flex items-center gap-3">
        <span class="topic-sigil" aria-hidden="true"></span>
        <h2 class="text-lg font-semibold">Категорії</h2>
      </div>
      <ul class="mt-5 flex flex-wrap gap-2">
        {CATEGORIES.map(category => (
          <li>
            <a
              href={getRelativeLocaleUrl(locale, `categories/${category.slug}`)}
              class="border-border bg-background/35 hover:border-accent hover:text-accent inline-block border px-3 py-1.5 text-sm"
            >
              {category.title}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <div class="flex items-center gap-3">
        <span class="topic-sigil" aria-hidden="true"></span>
        <h2 class="text-lg font-semibold">Тематичні хаби</h2>
      </div>
      <ul class="mt-5 space-y-4">
        {TOPIC_HUBS.map(topic => (
          <li class="border-border/70 border-s ps-4">
            <a
              href={getRelativeLocaleUrl(locale, `topics/${topic.slug}`)}
              class="hover:text-accent font-medium underline decoration-dashed underline-offset-4"
            >
              {topic.ukrainianTitle}
            </a>
            <p class="mt-1 text-muted-foreground text-sm leading-6">{topic.description}</p>
          </li>
        ))}
      </ul>
    </section>
  </div>
</nav>
