---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { getPublishedPosts } from "@/utils/getPublishedPosts";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const posts = (await getPublishedPosts()).filter(post => Boolean(post.data.series));
const series = [
  ...new Set(
    posts
      .map(post => post.data.series)
      .filter((value): value is string => typeof value === "string")
  ),
];
---

<Layout
  title={`Серії | ${config.site.title}`}
  description="Серії Тіньової карти для довгих тематичних циклів і тематичного авторитету."
>
  <Header />
  <Breadcrumb />
  <Main pageTitle="Серії" pageDesc="Механіка для майбутніх циклів статей. Серії з'являються тут автоматично після додавання frontmatter `series`.">
    {series.length > 0 ? (
      <ul class="grid gap-4 sm:grid-cols-2">
        {series.map(item => (
          <li class="border-border bg-muted/30 border p-4">
            <a href={getRelativeLocaleUrl(locale, `series/${item}`)} class="text-accent font-medium underline decoration-dashed underline-offset-4">
              {item}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-muted-foreground">Серії готові до першого циклу матеріалів.</p>
    )}
  </Main>
  <Footer />
</Layout>
