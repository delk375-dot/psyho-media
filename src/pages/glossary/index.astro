---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { GLOSSARY_TERMS } from "@/data/knowledge";
import config from "@/config";
---

<Layout
  title={`Глосарій | ${config.site.title}`}
  description="Глосарій Тіньової карти для семантичного індексування понять влади, статусу, переговорів, конфліктів і соціальних систем."
>
  <Header />
  <Breadcrumb />
  <Main pageTitle="Глосарій" pageDesc="Короткі визначення понять для AI search, long-tail запитів і внутрішнього зв'язування матеріалів.">
    <dl class="grid gap-4 sm:grid-cols-2">
      {GLOSSARY_TERMS.map(term => (
        <div class="border-border bg-muted/30 border p-4">
          <dt class="text-lg font-semibold">{term.title}</dt>
          <dd class="mt-2 text-muted-foreground">{term.description}</dd>
        </div>
      ))}
    </dl>
  </Main>
  <Footer />
</Layout>