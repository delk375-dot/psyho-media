---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { COLLECTIONS } from "@/data/knowledge";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
---

<Layout
  title={`Колекції | ${config.site.title}`}
  description="Колекції Людського механізму для тематичних маршрутів читання про стосунки, маніпуляції, гроші, секс і конфлікти."
>
  <Header />
  <Breadcrumb />
  <Main pageTitle="Колекції" pageDesc="Тематичні маршрути читання для тих, хто хоче розібрати не одну ситуацію, а повторюваний психологічний механізм.">
    <ul class="grid gap-4 sm:grid-cols-2">
      {COLLECTIONS.map(collection => (
        <li class="border-border bg-muted/30 border p-4">
          <a href={getRelativeLocaleUrl(locale, `collections/${collection.slug}`)} class="group block">
            <h2 class="text-xl font-semibold group-hover:text-accent">{collection.title}</h2>
            <p class="mt-2 text-muted-foreground">{collection.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </Main>
  <Footer />
</Layout>
