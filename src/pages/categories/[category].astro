---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Card from "@/components/Card.astro";
import Footer from "@/components/Footer.astro";
import { CATEGORIES } from "@/data/categories";
import { TOPIC_HUBS } from "@/data/knowledge";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPublishedPosts } from "@/utils/getPublishedPosts";
import { slugifyAll } from "@/utils/slugify";
import config from "@/config";

type Props = {
  category: (typeof CATEGORIES)[number];
};

export const getStaticPaths = (() =>
  CATEGORIES.map(category => ({
    params: { category: category.slug },
    props: { category },
  }))) satisfies GetStaticPaths;

const { category } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const posts = await getPublishedPosts();
const categoryPosts = getSortedPosts(
  posts.filter(({ data }) => {
    const tags = slugifyAll(data.tags);
    return data.category === category.slug || tags.includes(category.slug);
  })
);
const relatedHubs = TOPIC_HUBS.filter(topic =>
  (topic.categories as readonly string[]).includes(category.slug)
);
---

<Layout
  title={`${category.title} | ${config.site.title}`}
  description={category.description}
>
  <Header />

  <Breadcrumb />

  <Main pageTitle={category.title} pageDesc={category.description}>
    <section class="border-border bg-muted/20 border p-4">
      <h2 class="text-xl font-semibold">Психологічний профіль</h2>
      <p class="mt-2 text-muted-foreground">Фокус: {category.intent}</p>
      <ul class="mt-3 flex flex-wrap gap-2">
        {category.keywords.map(keyword => (
          <li class="border-border border px-2 py-1 text-sm">{keyword}</li>
        ))}
      </ul>
    </section>

    {relatedHubs.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-semibold">Пов'язані хаби</h2>
        <ul class="mt-3 grid gap-3 sm:grid-cols-2">
          {relatedHubs.map(topic => (
            <li class="border-border border p-3">
              <a
                href={getRelativeLocaleUrl(locale, `topics/${topic.slug}`)}
                class="text-accent font-medium underline decoration-dashed underline-offset-4"
              >
                {topic.ukrainianTitle}
              </a>
              <p class="mt-2 text-sm text-muted-foreground">{topic.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="mt-8">
      <h2 class="text-xl font-semibold">Матеріали категорії</h2>
      {
        categoryPosts.length > 0 ? (
          <ul>
            {categoryPosts.map(data => (
              <Card {...data} />
            ))}
          </ul>
        ) : (
          <p class="mt-3 text-muted-foreground">
            Категорія готова до першої публікації.
          </p>
        )
      }
    </section>
  </Main>

  <Footer />
</Layout>
