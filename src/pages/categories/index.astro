---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import KnowledgeGraphNav from "@/components/KnowledgeGraphNav.astro";
import { CATEGORIES } from "@/data/categories";
import { TOPIC_HUBS } from "@/data/knowledge";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
---

<Layout
  title={`Категорії знань | ${config.site.title}`}
  description="Карта знань Тіньової карти для лідерства, переговорів, правової психології, соціальних систем, статусу, влади і комунікації."
>
  <Header />

  <Breadcrumb />

  <Main
    pageTitle="Категорії знань"
    pageDesc="Семантична структура платформи: категорії, тематичні центри, внутрішні зв'язки і майбутні кластери матеріалів."
  >
    <KnowledgeGraphNav />

    <section class="mt-10">
      <h2 class="text-2xl font-semibold">Тематичні кластери</h2>
      <ul class="mt-5 grid gap-4 sm:grid-cols-2">
        {CATEGORIES.map(category => (
          <li class="border-border bg-muted/30 p-4">
            <a
              href={getRelativeLocaleUrl(locale, `categories/${category.slug}`)}
              class="group block"
            >
              <h3 class="text-xl font-semibold group-hover:text-accent">
                {category.title}
              </h3>
              <p class="mt-2 text-muted-foreground">{category.description}</p>
              <p class="mt-3 text-sm text-muted-foreground">
                Намір: {category.intent}
              </p>
            </a>
            <ul class="mt-3 flex flex-wrap gap-2">
              {category.hubs.map(hubSlug => {
                const hub = TOPIC_HUBS.find(topic => topic.slug === hubSlug);
                return hub ? (
                  <li>
                    <a
                      href={getRelativeLocaleUrl(locale, `topics/${hub.slug}`)}
                      class="text-accent text-sm underline decoration-dashed underline-offset-4"
                    >
                      {hub.ukrainianTitle}
                    </a>
                  </li>
                ) : null;
              })}
            </ul>
          </li>
        ))}
      </ul>
    </section>
  </Main>

  <Footer />
</Layout>