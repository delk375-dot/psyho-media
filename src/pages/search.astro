---
import { getRelativeLocaleUrl } from "astro:i18n";
import "@pagefind/default-ui/css/ui.css";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getAssetPath } from "@/utils/withBase";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

// Redirect to 404 if Pagefind is not configured
const notFoundUrl = getRelativeLocaleUrl(locale, "404");
if (config.features.search !== "pagefind" && notFoundUrl) {
  return Astro.rewrite(notFoundUrl);
}

const pagefindBundlePath = getAssetPath("pagefind/");
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;

const PAGE_TITLE = "Пошук по людських механізмах";
const PAGE_DESC =
  "Шукай не тільки слова, а й ситуації: ігнор, ревнощі, залежність, мовчання, гроші, статус.";
const META_DESC =
  "Пошук по психологічному медіа про стосунки, маніпуляції, ревнощі, гроші, секс і приховані мотиви.";

const SUGGESTIONS = [
  "ігнор",
  "ревнощі",
  "емоційна залежність",
  "мовчання",
  "токсичні люди",
  "гроші",
  "статус",
  "секс",
  "маніпуляція",
  "казки",
];
---

<Layout
  title={`${PAGE_TITLE} | ${config.site.title}`}
  description={META_DESC}
  canonicalURL={canonicalURL}
  noindex={true}
>
  <Header />

  <main id="main-content" class="app-layout pb-16">
    <!-- Page header -->
    <div class="search-page-header">
      <h1 class="search-page-title">{PAGE_TITLE}</h1>
      <p class="search-page-desc">{PAGE_DESC}</p>
    </div>

    <!-- Search widget (Pagefind UI) -->
    <div
      id="pagefind-search"
      transition:persist
      data-bundle-path={pagefindBundlePath}
    >
    </div>

    <!-- Result count (populated by JS) -->
    <p id="search-result-count" class="search-result-count" aria-live="polite"></p>

    <!-- Search suggestions -->
    <div class="search-suggestions" id="search-suggestions">
      <p class="search-suggestions-label">Спробуйте пошукати:</p>
      <div class="search-suggestions-chips">
        {
          SUGGESTIONS.map(term => (
            <button
              class="search-suggestion-chip"
              type="button"
              data-term={term}
              aria-label={`Шукати "${term}"`}
            >
              {term}
            </button>
          ))
        }
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  /**
   * Initialise Pagefind UI and wire up search suggestions.
   * Loaded only on /search — not on the rest of the site.
   */
  function initSearch() {
    const pagefindEl = document.getElementById("pagefind-search");
    if (!pagefindEl) return;

    const bundlePath = (pagefindEl as HTMLElement).dataset?.bundlePath;
    if (!bundlePath) return;

    const params = new URLSearchParams(window.location.search);

    const onIdle = window.requestIdleCallback || ((cb: () => void) => setTimeout(cb, 1));

    onIdle(async () => {
      // Dev-mode warning
      if (import.meta.env.DEV) {
        const devWarn = document.createElement("div");
        devWarn.className = "search-dev-warning";
        devWarn.innerHTML = `
          <strong>DEV mode:</strong> Build the project at least once to see results.
          <code>pnpm run build</code>
        `;
        pagefindEl.prepend(devWarn);
      }

      // @ts-expect-error — no types for @pagefind/default-ui
      const { PagefindUI } = await import("@pagefind/default-ui");

      const search = new PagefindUI({
        element: "#pagefind-search",
        bundlePath,
        showImages: false,
        showSubResults: true,
        resetStyles: false,
        debounceTimeoutMs: 300,
        processTerm(term: string) {
          // Sync URL ?q= param
          const p = new URLSearchParams(window.location.search);
          if (term) {
            p.set("q", term);
          } else {
            p.delete("q");
          }
          history.replaceState(
            history.state,
            "",
            term ? `?${p.toString()}` : window.location.pathname
          );
          sessionStorage.setItem("backUrl", window.location.href);
          updateSuggestions(term);
          return term;
        },
      });

      // Pre-fill from URL ?q=
      const initialQuery = params.get("q");
      if (initialQuery) {
        search.triggerSearch(initialQuery);
        updateSuggestions(initialQuery);
      }

      // Reset URL when search is cleared
      const input = document.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
      const clearBtn = document.querySelector(".pagefind-ui__search-clear");

      function onInputChange(e: Event) {
        const val = (e.target as HTMLInputElement)?.value?.trim();
        if (!val) {
          history.replaceState(history.state, "", window.location.pathname);
          updateSuggestions("");
          setResultCount(null);
        }
      }

      input?.addEventListener("input", onInputChange);
      clearBtn?.addEventListener("click", () => {
        history.replaceState(history.state, "", window.location.pathname);
        updateSuggestions("");
        setResultCount(null);
      });

      // Watch for result DOM changes to update result count
      observeResults();

      // Wire suggestion chips
      wireSuggestions(search);
    });
  }

  /** Show/hide suggestions block when searching */
  function updateSuggestions(term: string) {
    const block = document.getElementById("search-suggestions");
    if (block) {
      block.style.display = term.trim() ? "none" : "";
    }
  }

  /** Observe Pagefind results list and update count */
  function observeResults() {
    const container = document.getElementById("pagefind-search");
    if (!container) return;

    const observer = new MutationObserver(() => {
      const results = container.querySelectorAll(".pagefind-ui__result");
      const message = container.querySelector(".pagefind-ui__message");
      const input = container.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
      const query = input?.value?.trim();

      if (!query) {
        setResultCount(null);
        return;
      }

      if (message?.textContent?.includes("No results")) {
        setResultCount(0);
      } else if (results.length > 0) {
        setResultCount(results.length);
      }
    });

    observer.observe(container, { childList: true, subtree: true });
  }

  function setResultCount(count: number | null) {
    const el = document.getElementById("search-result-count");
    if (!el) return;
    if (count === null) {
      el.textContent = "";
    } else if (count === 0) {
      el.textContent = "Нічого не знайдено — спробуй інше слово або підказки нижче";
    } else {
      el.textContent = `Знайдено результатів: ${count}`;
    }
  }

  /** Attach click handlers to suggestion chips */
  function wireSuggestions(searchInstance: { triggerSearch: (q: string) => void }) {
    const chips = document.querySelectorAll<HTMLButtonElement>(".search-suggestion-chip");
    chips.forEach(chip => {
      chip.addEventListener("click", () => {
        const term = chip.dataset.term ?? "";
        if (!term) return;

        // Fill the Pagefind input
        const input = document.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
        if (input) {
          const nativeInputSetter = Object.getOwnPropertyDescriptor(
            window.HTMLInputElement.prototype,
            "value"
          )?.set;
          nativeInputSetter?.call(input, term);
          input.dispatchEvent(new Event("input", { bubbles: true }));
        }

        // Trigger Pagefind search
        searchInstance.triggerSearch(term);
        updateSuggestions(term);

        // Scroll to results
        document.getElementById("pagefind-search")?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });
  }

  // Init on page load and after View Transition swaps
  document.addEventListener("astro:page-load", () => {
    const pagefindSearch = document.querySelector("#pagefind-search");
    if (pagefindSearch && pagefindSearch.querySelector("form")) return;
    initSearch();
  });
  initSearch();
</script>

<style is:global>
  /* ── Pagefind UI theming ──────────────────────────────────── */
  #pagefind-search {
    --pagefind-ui-font: var(--font-app);
    --pagefind-ui-text: var(--foreground);
    --pagefind-ui-background: var(--background);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-tag: var(--background);
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;

    margin-top: 1.5rem;
  }

  #pagefind-search form::before {
    background-color: var(--foreground);
  }

  #pagefind-search input {
    font-size: 1.05rem;
    font-weight: 400;
    border: 1.5px solid var(--border);
    background: var(--background);
    color: var(--foreground);
    border-radius: 0.5rem;
    padding: 0.65rem 1rem 0.65rem 2.75rem;
  }

  #pagefind-search input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-color: var(--accent);
  }

  /* Result cards — editorial style */
  #pagefind-search .pagefind-ui__results {
    margin-top: 1.25rem;
  }

  #pagefind-search .pagefind-ui__result {
    border: 1px solid var(--border);
    border-radius: 0.625rem;
    padding: 1.1rem 1.25rem;
    margin-bottom: 0.75rem;
    background: color-mix(in srgb, var(--background) 96%, var(--muted));
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }

  #pagefind-search .pagefind-ui__result:hover {
    box-shadow: 0 4px 20px color-mix(in srgb, var(--accent) 14%, transparent);
    border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
  }

  #pagefind-search .pagefind-ui__result:last-of-type {
    border-bottom: 1px solid var(--border);
  }

  #pagefind-search .pagefind-ui__result-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }

  #pagefind-search .pagefind-ui__result-title a {
    color: var(--accent);
    text-decoration: none;
    text-underline-offset: 4px;
  }

  #pagefind-search .pagefind-ui__result-title a:hover {
    text-decoration: underline;
    text-decoration-style: dashed;
  }

  #pagefind-search .pagefind-ui__result-title a:focus-visible,
  #pagefind-search .pagefind-ui__search-clear:focus-visible {
    outline: 2px dashed var(--accent);
    outline-offset: 2px;
  }

  #pagefind-search .pagefind-ui__result-excerpt {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--muted-foreground);
  }

  /* Highlight matching words */
  #pagefind-search mark {
    background: color-mix(in srgb, var(--accent) 22%, transparent);
    color: var(--foreground);
    border-radius: 2px;
    padding: 0 2px;
  }

  #pagefind-search .pagefind-ui__result-nested {
    border-top: 1px dashed var(--border);
    margin-top: 0.75rem;
    padding-top: 0.75rem;
  }

  #pagefind-search .pagefind-ui__result-nested .pagefind-ui__result-link::before {
    font-family: system-ui;
  }

  #pagefind-search .pagefind-ui__button {
    border: 1.5px solid var(--border);
    border-radius: 0.5rem;
    background: transparent;
    color: var(--foreground);
    font-weight: 600;
    transition: border-color 0.15s, background 0.15s;
  }

  #pagefind-search .pagefind-ui__button:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  #pagefind-search .pagefind-ui__message {
    font-size: 0.9rem;
    color: var(--muted-foreground);
    margin-top: 1rem;
  }

  /* Dev warning */
  .search-dev-warning {
    background: color-mix(in srgb, var(--muted) 60%, transparent);
    border-radius: 0.5rem;
    padding: 0.85rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .search-dev-warning code {
    display: block;
    background: #1e1e1e;
    color: #d4d4d4;
    border-radius: 0.3rem;
    padding: 0.35rem 0.65rem;
    margin-top: 0.5rem;
    font-size: 0.83rem;
  }
</style>

<style>
  /* ── Page layout ─────────────────────────────────────────── */
  .search-page-header {
    padding-top: 2.5rem;
    padding-bottom: 0.25rem;
    max-width: 42rem;
  }

  .search-page-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: clamp(1.55rem, 4vw, 2.1rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--foreground);
  }

  .search-page-desc {
    margin-top: 0.6rem;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--muted-foreground);
    font-style: italic;
  }

  /* ── Result count ────────────────────────────────────────── */
  .search-result-count {
    font-size: 0.8rem;
    color: var(--muted-foreground);
    margin-top: 0.25rem;
    min-height: 1.2em;
  }

  /* ── Suggestions ─────────────────────────────────────────── */
  .search-suggestions {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .search-suggestions-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted-foreground);
    margin-bottom: 0.85rem;
  }

  .search-suggestions-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .search-suggestion-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--foreground);
    font-size: 0.875rem;
    cursor: pointer;
    transition:
      background 0.14s ease,
      border-color 0.14s ease,
      color 0.14s ease;
  }

  .search-suggestion-chip:hover,
  .search-suggestion-chip:focus-visible {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border-color: var(--accent);
    color: var(--accent);
    outline: none;
  }
</style>
