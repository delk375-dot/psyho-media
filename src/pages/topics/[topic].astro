---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { GetStaticPaths } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Card from "@/components/Card.astro";
import Footer from "@/components/Footer.astro";
import { CATEGORIES } from "@/data/categories";
import { TOPIC_HUBS } from "@/data/knowledge";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPublishedPosts } from "@/utils/getPublishedPosts";
import config from "@/config";

type Props = {
  topic: (typeof TOPIC_HUBS)[number];
};

export const getStaticPaths = (() =>
  TOPIC_HUBS.map(topic => ({
    params: { topic: topic.slug },
    props: { topic },
  }))) satisfies GetStaticPaths;

const { topic } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const posts = await getPublishedPosts();
const topicPosts = getSortedPosts(
  posts.filter(({ data }) =>
    data.topics.includes(topic.slug) ||
    (data.category
      ? (topic.categories as readonly string[]).includes(data.category)
      : false) ||
    data.series === topic.slug ||
    data.collection === topic.slug
  )
);
const relatedCategories = CATEGORIES.filter(category =>
  (topic.categories as readonly string[]).includes(category.slug)
);
---

<Layout title={`${topic.ukrainianTitle} | ${config.site.title}`} description={topic.description}>
  <Header />
  <Breadcrumb />
  <Main pageTitle={topic.ukrainianTitle} pageDesc={topic.description}>
    <section class="border-border bg-muted/20 border p-4">
      <p class="text-muted-foreground text-sm uppercase tracking-[0.16em]">Тематичний хаб</p>
      <h2 class="mt-3 text-xl font-semibold">Ключові питання</h2>
      <ul class="mt-3 list-inside list-disc space-y-1 text-muted-foreground">
        {topic.starterQuestions.map(question => <li>{question}</li>)}
      </ul>
    </section>

    <section class="mt-8">
      <h2 class="text-xl font-semibold">Пов'язані категорії</h2>
      <ul class="mt-3 flex flex-wrap gap-2">
        {relatedCategories.map(category => (
          <li>
            <a
              href={getRelativeLocaleUrl(locale, `categories/${category.slug}`)}
              class="border-border hover:border-accent hover:text-accent inline-block border px-3 py-1 text-sm"
            >
              {category.title}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-8">
      <h2 class="text-xl font-semibold">Матеріали хабу</h2>
      {topicPosts.length > 0 ? (
        <ul>{topicPosts.map(post => <Card {...post} />)}</ul>
      ) : (
        <p class="mt-3 text-muted-foreground">
          Хаб підготовлений для майбутніх розборів і серій.
        </p>
      )}
    </section>
  </Main>
  <Footer />
</Layout>
