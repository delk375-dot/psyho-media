---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { TOPIC_HUBS } from "@/data/knowledge";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
---

<Layout
  title={`Тематичні хаби | ${config.site.title}`}
  description="Тематичні хаби Людського механізму для стосунків, маніпуляцій, грошей, сексу, самооцінки, родини і конфліктів."
>
  <Header />
  <Breadcrumb />
  <Main
    pageTitle="Тематичні хаби"
    pageDesc="Головні вузли медіа для серій, колекцій, кейсів і майбутніх психологічних розборів."
  >
    <ul class="grid gap-4 sm:grid-cols-2">
      {TOPIC_HUBS.map(topic => (
        <li class="border-border bg-muted/30 p-4">
          <a href={getRelativeLocaleUrl(locale, `topics/${topic.slug}`)} class="group block">
            <p class="text-muted-foreground text-sm uppercase tracking-[0.14em]">Тематичний хаб</p>
            <h2 class="mt-2 text-xl font-semibold group-hover:text-accent">
              {topic.ukrainianTitle}
            </h2>
            <p class="mt-2 text-muted-foreground">{topic.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </Main>
  <Footer />
</Layout>
