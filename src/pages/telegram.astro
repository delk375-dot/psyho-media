---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const TELEGRAM_URL = "https://t.me/psyho_media";

const CONTENT_TYPES = [
  {
    icon: "⚡",
    title: "Сигнали",
    desc: "Короткі спостереження, які ловиш на льоту — до того, як вони стали статтею або зникли.",
  },
  {
    icon: "◼",
    title: "Фрагменти",
    desc: "Одна думка без вступу і висновку. Точка входу в механізм, а не повний розбір.",
  },
  {
    icon: "◐",
    title: "Темні спостереження",
    desc: "Про людей, якими ми не хочемо бути — але іноді все одно є. Без засудження, з розумінням.",
  },
  {
    icon: "⤴",
    title: "Мости",
    desc: "Telegram-пост, який починає тему. Стаття на сайті — де вона розкривається повністю.",
  },
  {
    icon: "◎",
    title: "Питання в темряві",
    desc: "Не відповіді. Питання, від яких стає некомфортно — і саме тому варто залишитися з ними.",
  },
];
---

<Layout
  title="Telegram — поле Людського механізму"
  description="Telegram — це поле. Сайт — це карта. Сигнали, фрагменти, мости між короткою думкою і повним розбором."
>
  <Header />
  <main id="main-content" class="app-layout">

    <!-- Hero -->
    <section class="tg-hero border-border border-b pt-14 pb-12 sm:pt-20 sm:pb-16">
      <p class="section-kicker">Канал</p>
      <h1 class="tg-hero-title">
        Telegram — це поле.<br class="hidden sm:block" />
        Сайт — це карта.
      </h1>
      <p class="tg-hero-desc">
        Тут з'являється те, що ще не стало статтею або ніколи нею не стане.<br class="hidden sm:block" />
        Сигнали, фрагменти, провокативні питання — між рядків.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <a
          id="tg-landing-cta"
          href={TELEGRAM_URL}
          class="tg-btn-primary"
          target="_blank"
          rel="noopener noreferrer"
          data-tg-signal-click
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
          Увійти в поле
        </a>
        <a href="/telegram/archive" class="tg-btn-secondary">
          Читати сигнали →
        </a>
      </div>
    </section>

    <!-- What's inside -->
    <section class="border-border border-b py-12 sm:py-16">
      <p class="section-kicker">Що в полі</p>
      <h2 class="section-title mb-10">П'ять типів сигналів</h2>
      <ul class="tg-features-grid">
        {CONTENT_TYPES.map(item => (
          <li class="tg-feature-card">
            <span class="tg-feature-icon" aria-hidden="true">{item.icon}</span>
            <h3 class="tg-feature-title">{item.title}</h3>
            <p class="tg-feature-desc">{item.desc}</p>
          </li>
        ))}
      </ul>
    </section>

    <!-- Final CTA -->
    <section class="py-14 sm:py-20 flex flex-col items-center text-center">
      <p class="tg-final-eyebrow">Поле активне</p>
      <h2 class="tg-final-title">Сигнали виходять<br />між статтями</h2>
      <p class="tg-final-desc">
        Деякі з них стануть механізмами. Деякі залишаться тільки там.
      </p>
      <a
        id="tg-landing-cta-bottom"
        href={TELEGRAM_URL}
        class="tg-btn-primary mt-8"
        target="_blank"
        rel="noopener noreferrer"
        data-tg-signal-click
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
        </svg>
        Читати сигнали
      </a>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────────────── */
  .tg-hero-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--foreground);
    margin: 0.75rem 0 0;
  }

  .tg-hero-desc {
    margin-top: 1.25rem;
    max-width: 44rem;
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.7;
    color: var(--muted-foreground);
  }

  /* ── Buttons ──────────────────────────────────────────────── */
  .tg-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.6rem;
    min-height: 44px;
    border-radius: 0.55rem;
    background: linear-gradient(135deg, #8f1028 0%, #b61f39 100%);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  @media (hover: hover) {
    .tg-btn-primary:hover { opacity: 0.88; }
  }

  .tg-btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.4rem;
    min-height: 44px;
    border-radius: 0.55rem;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--muted-foreground);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }

  @media (hover: hover) {
    .tg-btn-secondary:hover {
      border-color: var(--foreground);
      color: var(--foreground);
    }
  }

  /* ── Features grid ────────────────────────────────────────── */
  .tg-features-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tg-feature-card {
    padding: 1.5rem;
    border: 1.5px solid var(--border);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--accent) 3%, var(--background));
    transition: border-color 0.2s;
  }

  @media (hover: hover) {
    .tg-feature-card:hover {
      border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    }
  }

  .tg-feature-icon {
    display: block;
    font-size: 1.4rem;
    margin-bottom: 0.85rem;
    line-height: 1;
  }

  .tg-feature-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--foreground);
    margin: 0 0 0.5rem;
  }

  .tg-feature-desc {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--muted-foreground);
    margin: 0;
  }

  /* ── Final CTA section ────────────────────────────────────── */
  .tg-final-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1rem;
  }

  .tg-final-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--foreground);
    margin: 0 0 0.85rem;
  }

  .tg-final-desc {
    font-size: 1rem;
    color: var(--muted-foreground);
    margin: 0;
  }
</style>

<script>
  import { trackEvent, trackTelegramClick } from "@/utils/analytics";

  function initTelegramLanding() {
    if (!window.location.pathname.startsWith("/telegram") ||
        window.location.pathname.startsWith("/telegram/archive")) return;

    trackEvent("telegram_landing_view");

    document.querySelectorAll("[data-tg-signal-click]").forEach(el => {
      el.addEventListener("click", () => trackTelegramClick("telegram_page"));
    });
  }

  document.addEventListener("astro:page-load", initTelegramLanding);
  initTelegramLanding();
</script>
