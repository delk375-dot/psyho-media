---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import FormatBadge from "@/components/FormatBadge.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getPostUrl } from "@/utils/getPostPaths";
import { getPublishedPosts } from "@/utils/getPublishedPosts";
import { SERVICE_CTA } from "@/data/knowledge";
import { CATEGORIES } from "@/data/categories";
import { SEARCH_QUERIES, TOPIC_CLUSTERS } from "@/data/contentSystem";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const sortedPosts = await getPublishedPosts();
const homePath = getRelativeLocaleUrl(locale, "");

const byType = (type: string, limit = 4) =>
  sortedPosts
    .filter(post => post.data.contentType === type)
    .slice(0, limit);

// 3 найновіших матеріали будь-якого типу
const freshPosts = sortedPosts.slice(0, 3);

const viralNotes    = byType("viral_note", 3);
const fragments     = byType("psychological_fragment", 6);
const deepAnalysis  = byType("deep_analysis", 3);
const pillarArticles = byType("pillar_article", 4);

const navCategories = CATEGORIES.filter(c =>
  ["relationships","manipulation","jealousy","money-status","emotional-dependence","silence-ghosting","toxic-people","conflicts"].includes(c.slug)
);

// Нові жанри
const fairytales     = byType("psychological_fairytale", 3);
const socialBugs     = byType("social_bug", 3);
const humanScenarios = byType("human_scenario", 3);
const darkMechanisms = byType("dark_mechanism", 3);
const behaviorLab    = byType("behavior_lab", 3);

// Тільки перші 3 сервіси для м'якого CTA
const featuredServices = SERVICE_CTA.slice(0, 3);
---

<Layout
  title="Людський механізм — психологія стосунків, грошей, сексу і маніпуляцій"
  description="Масове психологічне медіа про стосунки, ревнощі, зради, маніпуляції, токсичних людей, гроші, секс, конфлікти і приховані мотиви поведінки."
>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >

    <!-- ═══════════════════════════════════════
         1. HERO
    ═══════════════════════════════════════ -->
    <section id="hero" class="relative overflow-hidden border-border border-b pt-12 pb-10 sm:pt-18 sm:pb-14">
      <div class="relative z-10 grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,0.72fr)] lg:items-center">
        <div class="max-w-3xl">
          <p class="section-kicker">Психологія повсякденних драм</p>

          <h1 class="mt-7 text-5xl leading-[1.05] font-semibold tracking-normal sm:text-7xl">
            Людський механізм
          </h1>

          <p class="hero-statement mt-7 max-w-2xl">
            Люди рідко говорять прямо. Особливо коли бояться втратити контроль.
          </p>

          <p class="mt-5 max-w-2xl text-base leading-8 text-muted-foreground sm:text-lg sm:leading-8">
            Розбираємо ревнощі, мовчання, маніпуляції, залежність і приховані
            мотиви — без зайвого пафосу і псевдонаукових кліше.
          </p>

          <div class="mt-10 flex flex-wrap gap-3 sm:mt-12">
            <LinkButton
              href={getRelativeLocaleUrl(locale, "posts")}
              class="bg-accent text-accent-foreground px-5 py-3 hover:opacity-90"
            >
              Читати розбори
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
            <LinkButton
              href={getRelativeLocaleUrl(locale, "categories")}
              class="border-border border px-5 py-3 hover:text-accent"
            >
              Усі теми
            </LinkButton>
          </div>
        </div>

        <div class="human-hero-mark hidden lg:block" aria-hidden="true">
          <span class="human-hero-heart">М</span>
          <span class="human-hero-line"></span>
          <span class="human-hero-note">без відповіді</span>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         2. СВІЖІ МАТЕРІАЛИ (3 останніх, будь-який тип)
    ═══════════════════════════════════════ -->
    <section id="fresh" class="content-lane border-border border-b py-10 sm:py-14">
      <div class="lane-header">
        <div>
          <p class="section-kicker">Щойно вийшло</p>
          <h2 class="section-title">Нові матеріали</h2>
        </div>
        <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
          Усі публікації
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
      <ul class="mt-4">
        {freshPosts.map(post => <Card variant="h3" {...post} />)}
      </ul>
    </section>

    <!-- ═══════════════════════════════════════
         3. ВІРУСНІ ЗАМІТКИ
    ═══════════════════════════════════════ -->
    <section id="viral-notes" class="content-lane border-border border-b py-10 sm:py-14">
      <div class="lane-header">
        <div>
          <FormatBadge contentType="viral_note" />
          <h2 class="section-title mt-3">Вірусні замітки</h2>
          <p class="section-copy">Коротко — але влучно. Одна болюча ситуація, один психологічний механізм.</p>
        </div>
      </div>
      <ul class="mt-4">
        {viralNotes.map(post => <Card variant="h3" {...post} />)}
      </ul>
    </section>

    <!-- ═══════════════════════════════════════
         4. ПСИХОЛОГІЧНІ ФРАГМЕНТИ
    ═══════════════════════════════════════ -->
    <section id="fragments" class="border-border border-b py-10 sm:py-14">
      <div class="lane-header">
        <div>
          <FormatBadge contentType="psychological_fragment" />
          <h2 class="section-title mt-3">Психологічні фрагменти</h2>
          <p class="section-copy">Одна думка, яку хочеться переслати. Або зберегти і перечитати пізно вночі.</p>
        </div>
      </div>
      <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {fragments.map(post => (
          <li>
            <a href={getPostUrl(post.id, post.filePath, locale)} class="fragment-card block min-h-full">
              <span class="fragment-card-format">Фрагмент</span>
              <strong>{post.data.title}</strong>
              <span>{post.data.description}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- ═══════════════════════════════════════
         5. ГЛИБОКІ РОЗБОРИ
    ═══════════════════════════════════════ -->
    <section id="deep-analysis" class="content-lane border-border border-b py-10 sm:py-14">
      <div class="lane-header">
        <div>
          <FormatBadge contentType="deep_analysis" />
          <h2 class="section-title mt-3">Глибокі розбори</h2>
          <p class="section-copy">Механізм поведінки — від поверхні до причини. Без поспіху.</p>
        </div>
      </div>
      <ul class="mt-4">
        {deepAnalysis.map(post => <Card variant="h3" {...post} />)}
      </ul>
    </section>

    <!-- ═══════════════════════════════════════
         6. ФУНДАМЕНТАЛЬНІ РОЗБОРИ
    ═══════════════════════════════════════ -->
    <section id="pillar-articles" class="content-lane border-border border-b py-10 sm:py-14">
      <div class="lane-header">
        <div>
          <FormatBadge contentType="pillar_article" />
          <h2 class="section-title mt-3">Фундаментальні розбори</h2>
          <p class="section-copy">Великі матеріали про те, як влаштовані стосунки, влада і поведінка людини зсередини.</p>
        </div>
        <LinkButton href={getRelativeLocaleUrl(locale, "topics")}>
          Тематичні хаби
        </LinkButton>
      </div>
      <ul class="mt-4">
        {pillarArticles.map(post => <Card variant="h3" {...post} />)}
      </ul>
    </section>

    <!-- ═══════════════════════════════════════
         7A. ПСИХОЛОГІЧНІ КАЗКИ
    ═══════════════════════════════════════ -->
    {fairytales.length > 0 && (
    <section id="fairytales" class="content-lane border-border border-b py-10 sm:py-14">
      <div class="lane-header">
        <div>
          <FormatBadge contentType="psychological_fairytale" />
          <h2 class="section-title mt-3">Психологічні казки</h2>
          <p class="section-copy">Мудреці, дзеркала, архетипи і притчі. Не для дітей — для дорослих, які ще не все зрозуміли про себе.</p>
        </div>
        <LinkButton href={getRelativeLocaleUrl(locale, "categories/fairytales")}>
          Усі казки
        </LinkButton>
      </div>
      <ul class="mt-4">
        {fairytales.map(post => <Card variant="h3" {...post} />)}
      </ul>
    </section>
    )}

    <!-- ═══════════════════════════════════════
         7B. СОЦІАЛЬНІ БАГИ
    ═══════════════════════════════════════ -->
    {socialBugs.length > 0 && (
    <section id="social-bugs" class="content-lane border-border border-b py-10 sm:py-14">
      <div class="lane-header">
        <div>
          <FormatBadge contentType="social_bug" />
          <h2 class="section-title mt-3">Соціальні баги</h2>
          <p class="section-copy">Іронія, абсурд і людські глюки. Впізнаєш себе — сміятись або рефлексувати, вибір твій.</p>
        </div>
        <LinkButton href={getRelativeLocaleUrl(locale, "categories/social-bugs")}>
          Усі баги
        </LinkButton>
      </div>
      <ul class="mt-4">
        {socialBugs.map(post => <Card variant="h3" {...post} />)}
      </ul>
    </section>
    )}

    <!-- ═══════════════════════════════════════
         7C. ЛЮДСЬКІ СЦЕНАРІЇ
    ═══════════════════════════════════════ -->
    {humanScenarios.length > 0 && (
    <section id="human-scenarios" class="content-lane border-border border-b py-10 sm:py-14">
      <div class="lane-header">
        <div>
          <FormatBadge contentType="human_scenario" />
          <h2 class="section-title mt-3">Людські сценарії</h2>
          <p class="section-copy">Психологія через сюжет. Реальні або майже реальні ситуації — моральна неоднозначність включена.</p>
        </div>
        <LinkButton href={getRelativeLocaleUrl(locale, "categories/human-scenarios")}>
          Усі сценарії
        </LinkButton>
      </div>
      <ul class="mt-4">
        {humanScenarios.map(post => <Card variant="h3" {...post} />)}
      </ul>
    </section>
    )}

    <!-- ═══════════════════════════════════════
         7D. ТЕМНІ МЕХАНІЗМИ
    ═══════════════════════════════════════ -->
    {darkMechanisms.length > 0 && (
    <section id="dark-mechanisms" class="content-lane border-border border-b py-10 sm:py-14">
      <div class="lane-header">
        <div>
          <FormatBadge contentType="dark_mechanism" />
          <h2 class="section-title mt-3">Темні механізми</h2>
          <p class="section-copy">Газлайтинг, прихований контроль, емоційна плутанина. Те, про що не кажуть прямо — але роблять.</p>
        </div>
        <LinkButton href={getRelativeLocaleUrl(locale, "categories/dark-mechanisms")}>
          Усі механізми
        </LinkButton>
      </div>
      <ul class="mt-4">
        {darkMechanisms.map(post => <Card variant="h3" {...post} />)}
      </ul>
    </section>
    )}

    <!-- ═══════════════════════════════════════
         7E. ЛАБОРАТОРІЯ ПОВЕДІНКИ
    ═══════════════════════════════════════ -->
    {behaviorLab.length > 0 && (
    <section id="behavior-lab" class="content-lane border-border border-b py-10 sm:py-14">
      <div class="lane-header">
        <div>
          <FormatBadge contentType="behavior_lab" />
          <h2 class="section-title mt-3">Лабораторія поведінки</h2>
          <p class="section-copy">Готтман, Скіннер, Каннеман і реальні дослідження. Поведінкова наука — без академічної сухості.</p>
        </div>
        <LinkButton href={getRelativeLocaleUrl(locale, "categories/behavior-science")}>
          Усі дослідження
        </LinkButton>
      </div>
      <ul class="mt-4">
        {behaviorLab.map(post => <Card variant="h3" {...post} />)}
      </ul>
    </section>
    )}

    <!-- ═══════════════════════════════════════
         7. НАВІГАЦІЯ ПО ТЕМАХ
    ═══════════════════════════════════════ -->
    <section id="topics" class="border-border border-b py-10 sm:py-14">
      <div class="max-w-2xl">
        <p class="section-kicker">Карта тем</p>
        <h2 class="section-title">Знайди своє питання</h2>
        <p class="section-copy">
          Стосунки, маніпуляції, ревнощі, гроші, залежність — кожна тема веде до серії матеріалів.
        </p>
      </div>

      <ul class="mt-8 grid gap-4 sm:grid-cols-2">
        {TOPIC_CLUSTERS.map(cluster => (
          <li>
            <a href={cluster.href} class="topic-cluster-card block min-h-full">
              <strong>{cluster.title}</strong>
              <span>{cluster.description}</span>
            </a>
          </li>
        ))}
      </ul>

      <ul class="mt-6 flex flex-wrap gap-3">
        {navCategories.map(category => (
          <li>
            <a href={getRelativeLocaleUrl(locale, `categories/${category.slug}`)} class="topic-chip block">
              {category.title}
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- ═══════════════════════════════════════
         8. ПОШУКОВІ ТРИВОГИ (SEO — внизу)
    ═══════════════════════════════════════ -->
    <section id="search-queries" class="border-border border-b py-10 sm:py-14">
      <div class="max-w-2xl">
        <p class="section-kicker">Питання, які шукають ночами</p>
        <h2 class="section-title">Впізнаєш себе?</h2>
      </div>

      <ul class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {SEARCH_QUERIES.map(query => (
          <li>
            <a href={query.href} class="query-card block min-h-full">
              <span class="query-card-mark" aria-hidden="true"></span>
              <strong>{query.question}</strong>
              <span>Перейти до теми</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- ═══════════════════════════════════════
         8B. TELEGRAM — ATMOSPHERIC BLOCK
    ═══════════════════════════════════════ -->
    <section id="telegram-cta" class="border-border border-b py-10 sm:py-14">
      <div class="tg-home-block">
        <div class="tg-home-text">
          <p class="section-kicker">Telegram</p>
          <h2 class="tg-home-title">Telegram — це поле. Сайт — це карта.</h2>
          <p class="tg-home-desc">
            Сигнали, фрагменти, питання в темряві — між статтями і поза ними.
          </p>
        </div>
        <a
          id="home-telegram-cta"
          href="/telegram"
          class="tg-home-btn"
          aria-label="Читати сигнали в Telegram-каналі"
        >
          Читати сигнали →
        </a>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         9. ДОПОМОГА — М'ЯКИЙ CTA
         (зараз інформаційно, в майбутньому — коучинг / психолог / юрист)
    ═══════════════════════════════════════ -->
    <section id="help" class="border-border border-b py-10 sm:py-14">
      <div class="max-w-2xl">
        <p class="section-kicker">Коли читання стає замало</p>
        <h2 class="section-title">Іноді потрібен живий розбір</h2>
        <p class="section-copy">
          Стаття пояснює механізм. Але у твоїй ситуації — свої деталі, свій контекст і своя ставка.
          Ми готуємо формати живої підтримки: коучинг, консультація психолога, юридичний розбір ситуації.
        </p>
      </div>
      <ul class="mt-8 grid gap-5 sm:grid-cols-3">
        {featuredServices.map(service => (
          <li class="map-card border-border bg-muted/20 border p-5 sm:p-6">
            <span class="topic-sigil" aria-hidden="true"></span>
            <h3 class="mt-4 text-base font-semibold">{service.title}</h3>
            <p class="mt-3 text-sm leading-7 text-muted-foreground">
              {service.description}
            </p>
          </li>
        ))}
      </ul>
      <p class="mt-6 text-sm text-muted-foreground">
        Формати в розробці — <a href={getRelativeLocaleUrl(locale, "about")} class="underline underline-offset-4 hover:text-accent">дізнатись більше про проєкт</a>.
      </p>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Telegram home block ─────────────────────────────────── */
  .tg-home-block {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
    border: 1.5px solid var(--border);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--accent) 4%, var(--background));
    max-width: 44rem;
    transition: border-color 0.2s;
  }

  .tg-home-block:has(#home-telegram-cta:hover) {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
  }

  @media (min-width: 40rem) {
    .tg-home-block {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .tg-home-text { flex: 1; }

  .tg-home-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    font-weight: 700;
    line-height: 1.25;
    color: var(--foreground);
    margin: 0.4rem 0 0;
  }

  .tg-home-desc {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--muted-foreground);
  }

  .tg-home-btn {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    padding: 0.65rem 1.3rem;
    min-height: 44px;
    border-radius: 0.55rem;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--foreground);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .tg-home-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
</style>

<script>
  import { trackTelegramClick } from "@/utils/analytics";

  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }

    // GA4: home Telegram CTA — unified telegram_click with source param
    document.getElementById("home-telegram-cta")?.addEventListener("click", () => {
      trackTelegramClick("home");
    });
  });
</script>
