---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import InfluenceMap from "@/components/InfluenceMap.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { SERVICE_CTA } from "@/data/knowledge";
import config from "@/config";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;

const posts = await getCollection("posts", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
const latestPosts = sortedPosts.slice(0, postsConfig.perIndex);
const homePath = getRelativeLocaleUrl(locale, "");

const directionCards = [
  {
    title: "Психологія влади",
    description: "Страх, статус, контроль і поведінка керівників у системах впливу.",
    href: getRelativeLocaleUrl(locale, "topics/psychology-of-power"),
  },
  {
    title: "Соціальні ліфти",
    description: "Як системи піднімають, блокують і роблять людей видимими.",
    href: getRelativeLocaleUrl(locale, "topics/social-elevators"),
  },
  {
    title: "Анатомія переговорів",
    description: "Рамки, інтереси, домінування і прихована боротьба за контроль.",
    href: getRelativeLocaleUrl(locale, "topics/negotiation-anatomy"),
  },
  {
    title: "Маніпуляції",
    description: "Газлайтинг, тиск, інформаційне виснаження і захист автономії.",
    href: getRelativeLocaleUrl(locale, "categories/manipulation"),
  },
  {
    title: "Конфлікти",
    description: "Ескалація, межі, статусні травми і приховані вигоди сторін.",
    href: getRelativeLocaleUrl(locale, "categories/conflicts"),
  },
  {
    title: "Правова психологія",
    description: "Поведінка людей під юридичним ризиком, доказами і відповідальністю.",
    href: getRelativeLocaleUrl(locale, "topics/legal-psychology"),
  },
  {
    title: "Комунікація",
    description: "Мова влади, точність, управлінські розмови і довіра під тиском.",
    href: getRelativeLocaleUrl(locale, "categories/communication"),
  },
  {
    title: "Статус і влада",
    description: "Невидимі ранги, символічний капітал, легітимність і контроль.",
    href: getRelativeLocaleUrl(locale, "categories/status-and-power"),
  },
  {
    title: "Організаційна психологія",
    description: "Команди, культура, лояльність, саботаж і структура рішень.",
    href: getRelativeLocaleUrl(locale, "categories/organizational-psychology"),
  },
  {
    title: "Токсична ввічливість",
    description: "Коли пристойність маскує уникання, пасивну агресію і саботаж.",
    href: getRelativeLocaleUrl(locale, "topics/toxic-politeness"),
  },
];
---

<Layout
  title="Тіньова карта — закулісна аналітика влади, переговорів і соціальних систем"
  description="Інтелектуальна платформа про переговори, владу, соціальні механіки, статус, конфлікти та прихований вплив."
>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="relative overflow-hidden border-border border-b pt-16 pb-14 sm:pt-24 sm:pb-20">
      <div class="relative z-10 grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,0.9fr)] lg:items-center">
        <div class="max-w-3xl">
          <p class="text-muted-foreground text-sm leading-6 uppercase tracking-[0.22em]">
            Закулісна аналітика для керівників
          </p>

          <h1 class="mt-7 text-5xl leading-[1.05] font-semibold tracking-normal sm:text-7xl">
            Тіньова карта
          </h1>

          <p class="mt-8 max-w-2xl text-lg leading-8 text-muted-foreground sm:text-xl sm:leading-9">
            Платформа про приховані механіки влади, переговорів, статусу, конфліктів і
            соціального впливу. Тут досліджуються не офіційні декларації, а те, як
            системи реально поводяться під тиском страху, інтересу та комунікації.
          </p>

          <div class="mt-10 flex flex-wrap gap-3 sm:mt-12">
            <LinkButton
              href={getRelativeLocaleUrl(locale, "topics")}
              class="bg-accent text-accent-foreground px-5 py-3 hover:opacity-90"
            >
              Відкрити дослідження
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
            <LinkButton
              href={getRelativeLocaleUrl(locale, "categories")}
              class="border-border border px-5 py-3 hover:text-accent"
            >
              Архів тем
            </LinkButton>
          </div>
        </div>

        <InfluenceMap class="hidden lg:block" />
      </div>
    </section>

    <section id="research-archive" class="border-border border-b py-16 sm:py-24">
      <div class="max-w-2xl">
        <h2 class="text-3xl font-semibold tracking-normal">Архів досліджень</h2>
        <p class="mt-4 text-base leading-8 text-muted-foreground">
          Структурована база матеріалів про переговори, соціальні системи, владу,
          комунікацію, психологію конфліктів і приховані механіки впливу.
        </p>
      </div>

      <div class="mt-12">
        <h3 class="text-2xl font-semibold tracking-normal">Карта напрямків</h3>
        <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {directionCards.map(direction => (
            <li class="map-card border-border bg-muted/20 border p-5 sm:p-6">
              <a href={direction.href} class="group block min-h-full">
                <span class="topic-sigil" aria-hidden="true"></span>
                <h4 class="mt-4 text-lg font-semibold group-hover:text-accent">
                  {direction.title}
                </h4>
                <p class="mt-3 text-sm leading-7 text-muted-foreground">
                  {direction.description}
                </p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section id="latest-research" class="border-border border-b py-16 sm:py-24">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-semibold tracking-normal">Нові дослідження</h2>
      </div>

      {
        latestPosts.length > 0 ? (
          <ul class="mt-6">
            {latestPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        ) : (
          <p class="mt-4 text-muted-foreground">
            Архітектура готова до перших матеріалів.
          </p>
        )
      }

      <div class="mt-10">
        <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
          Переглянути всі дослідження
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </section>

    <section id="services" class="border-border border-b py-16 sm:py-24">
      <div class="max-w-2xl">
        <h2 class="text-2xl font-semibold tracking-normal">Практичні формати</h2>
      </div>
      <ul class="mt-8 grid gap-5 sm:grid-cols-2">
        {SERVICE_CTA.map(service => (
          <li class="map-card border-border bg-muted/20 border p-5 sm:p-6">
            <span class="topic-sigil" aria-hidden="true"></span>
            <h3 class="mt-4 text-lg font-semibold">{service.title}</h3>
            <p class="mt-3 text-sm leading-7 text-muted-foreground">
              {service.description}
            </p>
          </li>
        ))}
      </ul>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
