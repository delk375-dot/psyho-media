---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { SERVICE_CTA } from "@/data/knowledge";
import config from "@/config";
---

<Layout
  title={`Консультаційні формати | ${config.site.title}`}
  description="Плейсхолдери для коучингу керівників, аудиту комунікації, правової консультації і діагностики конфлікту."
>
  <Header />
  <Breadcrumb />
  <Main pageTitle="Консультаційні формати" pageDesc="Практичні блоки дії, які можна прив'язувати до статей, кейсів, хабів і категорій.">
    <ul class="grid gap-4 sm:grid-cols-2">
      {SERVICE_CTA.map(service => (
        <li class="border-border bg-muted/30 border p-4">
          <h2 class="text-xl font-semibold">{service.title}</h2>
          <p class="mt-2 text-muted-foreground">{service.description}</p>
        </li>
      ))}
    </ul>
  </Main>
  <Footer />
</Layout>
