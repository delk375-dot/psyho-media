---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const TELEGRAM_URL = "https://t.me/psyho_media";
const SITE_URL = "https://psyho-media.pp.ua";

const TYPE_LABELS: Record<string, string> = {
  signal:          "Сигнал",
  bridge:          "Міст",
  question:        "Питання",
  fragment:        "Фрагмент",
  case:            "Кейс",
  teaser:          "Анонс",
  afterthought:    "Afterthought",
  provocation:     "Провокація",
  shadow_fragment: "Тіньовий фрагмент",
  microcase:       "Мікрокейс",
};

const TONE_LABELS: Record<string, string> = {
  atmospheric: "Атмосферний",
  dark: "Темний",
  ironic: "Іронічний",
  analytical: "Аналітичний",
  provocative: "Провокативний",
  calm: "Спокійний",
};

const TYPE_CSS: Record<string, string> = {
  signal:          "type-signal",
  bridge:          "type-bridge",
  question:        "type-question",
  fragment:        "type-fragment",
  case:            "type-case",
  teaser:          "type-teaser",
  afterthought:    "type-afterthought",
  provocation:     "type-provocation",
  shadow_fragment: "type-shadow",
  microcase:       "type-microcase",
};

const TONE_CSS: Record<string, string> = {
  atmospheric: "tone-atmospheric",
  dark:        "tone-dark",
  ironic:      "tone-ironic",
  analytical:  "tone-analytical",
  provocative: "tone-provocative",
  calm:        "tone-calm",
};

const allPosts = await getCollection("telegram");
const sorted = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const allTypes = [...new Set(sorted.map(p => p.data.type))];
const allTones = [...new Set(sorted.map(p => p.data.tone).filter(Boolean))];

function formatDate(d: Date): string {
  return d.toLocaleDateString("uk-UA", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}
---

<Layout
  title="Архів сигналів — Telegram-поле Людського механізму"
  description="Фрагменти, сигнали, мости і питання з Telegram-каналу. Те, що з'являється між статтями."
>
  <Header />
  <main id="main-content" class="app-layout">

    <!-- Header -->
    <section class="border-border border-b pt-12 pb-10 sm:pt-16 sm:pb-12">
      <nav class="arc-breadcrumb" aria-label="Навігація">
        <a href="/telegram">← Поле</a>
      </nav>
      <p class="section-kicker mt-6">Архів сигналів</p>
      <h1 class="arc-title">Те, що виходило між статтями</h1>
      <p class="arc-desc">
        Коротко — але іноді точніше, ніж у лонгриді. Фрагменти, які не вмістились у карту.
      </p>
    </section>

    <!-- Filters -->
    <section class="arc-filters-bar border-border border-b py-4">
      <div class="arc-filters-inner">
        <div class="arc-filter-group" role="group" aria-label="Фільтр за типом">
          <span class="arc-filter-label">Тип</span>
          <button class="arc-filter-btn active" data-filter-type="all">Всі</button>
          {allTypes.map(t => (
            <button class="arc-filter-btn" data-filter-type={t}>
              {TYPE_LABELS[t] ?? t}
            </button>
          ))}
        </div>
        <div class="arc-filter-group" role="group" aria-label="Фільтр за тоном">
          <span class="arc-filter-label">Тон</span>
          <button class="arc-filter-btn active" data-filter-tone="all">Всі</button>
          {allTones.map(t => (
            <button class="arc-filter-btn" data-filter-tone={t}>
              {TONE_LABELS[t as string] ?? t}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Cards -->
    <section class="py-10 sm:py-14">
      <ul class="arc-grid" id="arc-cards">
        {sorted.map(post => (
          <li
            class="arc-card"
            data-type={post.data.type}
            data-tone={post.data.tone ?? ""}
          >
            <div class="arc-card-meta">
              <span class:list={["arc-type-badge", TYPE_CSS[post.data.type] ?? "type-signal"]}>
                {TYPE_LABELS[post.data.type] ?? post.data.type}
              </span>
              {post.data.tone && (
                <span class:list={["arc-tone-badge", TONE_CSS[post.data.tone] ?? ""]}>
                  {TONE_LABELS[post.data.tone] ?? post.data.tone}
                </span>
              )}
              {!post.data.isTelegramOnly && (
                <span class="arc-site-badge">Є механізм</span>
              )}
              <time class="arc-date" datetime={post.data.date.toISOString()}>
                {formatDate(post.data.date)}
              </time>
            </div>
            <h2 class="arc-card-title">{post.data.title}</h2>
            {post.data.body && (
              <p class="arc-card-body">{post.data.body}</p>
            )}
            <div class="arc-card-actions">
              {post.data.bridgeTo ? (
                <a
                  href={`${SITE_URL}${post.data.bridgeTo}`}
                  class="arc-card-cta arc-card-cta--bridge"
                  data-archive-bridge-click
                >
                  Читати механізм →
                </a>
              ) : (
                <a
                  href={TELEGRAM_URL}
                  class="arc-card-cta"
                  target="_blank"
                  rel="noopener noreferrer"
                  data-archive-cta
                >
                  Читати в Telegram →
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
      <p class="arc-empty hidden" id="arc-empty">
        Сигналів з цим фільтром поки немає.
      </p>
    </section>

    <!-- Bottom CTA -->
    <section class="border-border border-t py-12 sm:py-16 flex flex-col items-center text-center">
      <p class="arc-bottom-kicker">Поле активне</p>
      <h2 class="arc-bottom-title">Нові сигнали — в каналі</h2>
      <p class="arc-bottom-desc">
        Деякі з них стануть механізмами. Деякі залишаться тільки там.
      </p>
      <a
        href={TELEGRAM_URL}
        id="arc-main-cta"
        class="arc-cta-btn"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
        </svg>
        Увійти в поле
      </a>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Breadcrumb ───────────────────────────────────────────── */
  .arc-breadcrumb a {
    font-size: 0.85rem;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 0.15s;
  }
  @media (hover: hover) {
    .arc-breadcrumb a:hover { color: var(--accent); }
  }

  /* ── Header ───────────────────────────────────────────────── */
  .arc-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--foreground);
    margin: 0.5rem 0 0;
  }

  .arc-desc {
    margin-top: 1rem;
    max-width: 38rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted-foreground);
  }

  /* ── Filters ──────────────────────────────────────────────── */
  .arc-filters-bar {
    background: color-mix(in srgb, var(--background) 95%, var(--foreground) 5%);
  }

  .arc-filters-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    max-width: 72rem;
    padding: 0 1.5rem;
    margin: 0 auto;
  }

  .arc-filter-group {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .arc-filter-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-foreground);
    margin-right: 0.2rem;
  }

  .arc-filter-btn {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--muted-foreground);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .arc-filter-btn.active,
  .arc-filter-btn[aria-pressed="true"] {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  @media (hover: hover) {
    .arc-filter-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }
  }

  /* ── Grid ─────────────────────────────────────────────────── */
  .arc-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* ── Card ─────────────────────────────────────────────────── */
  .arc-card {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.5rem;
    border: 1.5px solid var(--border);
    border-radius: 0.75rem;
    background: var(--background);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .arc-card.hidden {
    display: none;
  }

  @media (hover: hover) {
    .arc-card:hover {
      border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
      box-shadow: 0 4px 16px color-mix(in srgb, var(--foreground) 6%, transparent);
    }
  }

  .arc-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* ── Type badges ──────────────────────────────────────────── */
  .arc-type-badge {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
  }

  .type-signal    { background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); }
  .type-bridge    { background: color-mix(in srgb, #2563eb 12%, transparent); color: #2563eb; }
  .type-question  { background: color-mix(in srgb, #7c3aed 12%, transparent); color: #7c3aed; }
  .type-fragment  { background: color-mix(in srgb, var(--foreground) 8%, transparent); color: var(--muted-foreground); }
  .type-case      { background: color-mix(in srgb, #059669 12%, transparent); color: #059669; }
  .type-teaser    { background: color-mix(in srgb, var(--accent) 8%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent); }

  /* ── After-reading pack type badges ──────────────────────── */
  .type-afterthought  { background: color-mix(in srgb, #0891b2 10%, transparent); color: #0891b2; }
  .type-provocation   { background: color-mix(in srgb, #dc2626 10%, transparent); color: #dc2626; }
  .type-shadow        { background: color-mix(in srgb, var(--foreground) 14%, transparent); color: var(--foreground); }
  .type-microcase     { background: color-mix(in srgb, #7c3aed 10%, transparent); color: #7c3aed; }

  /* ── Tone badges ──────────────────────────────────────────── */
  .arc-tone-badge {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--foreground) 6%, transparent);
    color: var(--muted-foreground);
  }

  .tone-dark        { background: color-mix(in srgb, var(--foreground) 10%, transparent); color: var(--foreground); }
  .tone-provocative { background: color-mix(in srgb, #dc2626 8%, transparent); color: #dc2626; }
  .tone-ironic      { background: color-mix(in srgb, #d97706 8%, transparent); color: #d97706; }
  .tone-analytical  { background: color-mix(in srgb, #0891b2 8%, transparent); color: #0891b2; }
  .tone-atmospheric { background: color-mix(in srgb, var(--accent) 7%, transparent); color: var(--muted-foreground); }
  .tone-calm        { background: color-mix(in srgb, #059669 6%, transparent); color: #059669; }

  /* ── Site-only badge ──────────────────────────────────────── */
  .arc-site-badge {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    background: color-mix(in srgb, #2563eb 8%, transparent);
    color: #2563eb;
    border: 1px solid color-mix(in srgb, #2563eb 18%, transparent);
  }

  .arc-date {
    font-size: 0.75rem;
    color: var(--muted-foreground);
    margin-left: auto;
  }

  .arc-card-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--foreground);
    margin: 0;
  }

  .arc-card-body {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--muted-foreground);
    margin: 0;
    flex: 1;
  }

  .arc-card-actions {
    margin-top: auto;
    padding-top: 0.15rem;
  }

  .arc-card-cta {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .arc-card-cta--bridge {
    color: #2563eb;
  }

  @media (hover: hover) {
    .arc-card-cta:hover { opacity: 0.75; }
  }

  /* ── Empty state ──────────────────────────────────────────── */
  .arc-empty {
    text-align: center;
    padding: 3rem 0;
    color: var(--muted-foreground);
    font-size: 0.95rem;
  }

  .arc-empty.hidden { display: none; }

  /* ── Bottom section ───────────────────────────────────────── */
  .arc-bottom-kicker {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.75rem;
  }

  .arc-bottom-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: clamp(1.35rem, 3vw, 1.9rem);
    font-weight: 700;
    color: var(--foreground);
    margin: 0 0 0.65rem;
  }

  .arc-bottom-desc {
    font-size: 0.92rem;
    color: var(--muted-foreground);
    margin: 0 0 1.5rem;
  }

  .arc-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.6rem;
    min-height: 44px;
    border-radius: 0.55rem;
    background: linear-gradient(135deg, #8f1028 0%, #b61f39 100%);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  @media (hover: hover) {
    .arc-cta-btn:hover { opacity: 0.88; }
  }
</style>

<script>
  /* eslint-disable @typescript-eslint/no-explicit-any */
  declare global {
    interface Window { gtag?: (...args: any[]) => void; }
  }

  function fireGA4(event: string, extra?: Record<string, unknown>) {
    try {
      if (typeof window.gtag === "function") {
        window.gtag("event", event, {
          page_location: window.location.href,
          page_title: document.title,
          ...extra,
        });
      }
    } catch { /* ignore */ }
  }

  // ── Filter state ────────────────────────────────────────────
  let activeType = "all";
  let activeTone = "all";

  function applyFilters() {
    const cards = document.querySelectorAll<HTMLElement>(".arc-card");
    let visible = 0;

    cards.forEach(card => {
      const typeMatch = activeType === "all" || card.dataset.type === activeType;
      const toneMatch = activeTone === "all" || card.dataset.tone === activeTone;
      const show = typeMatch && toneMatch;
      card.classList.toggle("hidden", !show);
      if (show) visible++;
    });

    const empty = document.getElementById("arc-empty");
    if (empty) empty.classList.toggle("hidden", visible > 0);
  }

  function setActiveFilter(buttons: NodeListOf<Element>, active: Element) {
    buttons.forEach(b => b.classList.remove("active"));
    active.classList.add("active");
  }

  function initArchive() {
    if (!window.location.pathname.startsWith("/telegram/archive")) return;

    fireGA4("telegram_archive_view");

    // Type filters
    const typeButtons = document.querySelectorAll("[data-filter-type]");
    typeButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        const t = (btn as HTMLElement).dataset.filterType ?? "all";
        activeType = t;
        setActiveFilter(typeButtons, btn);
        applyFilters();
        fireGA4("telegram_archive_filter", { filter_type: t, filter_dim: "type" });
      });
    });

    // Tone filters
    const toneButtons = document.querySelectorAll("[data-filter-tone]");
    toneButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        const t = (btn as HTMLElement).dataset.filterTone ?? "all";
        activeTone = t;
        setActiveFilter(toneButtons, btn);
        applyFilters();
        fireGA4("telegram_archive_filter", { filter_type: t, filter_dim: "tone" });
      });
    });

    // Bridge link clicks
    document.querySelectorAll("[data-archive-bridge-click]").forEach(el => {
      el.addEventListener("click", () => fireGA4("telegram_bridge_click"));
    });

    // Telegram CTA clicks
    document.querySelectorAll("[data-archive-cta]").forEach(el => {
      el.addEventListener("click", () => fireGA4("telegram_signal_click"));
    });
    document.getElementById("arc-main-cta")?.addEventListener("click", () => {
      fireGA4("telegram_signal_click");
    });
  }

  document.addEventListener("astro:page-load", initArchive);
  initArchive();
</script>
