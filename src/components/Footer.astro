---
import type { HTMLAttributes } from "astro/types";
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations } from "@/i18n";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const t = useTranslations(Astro.currentLocale);
const locale = Astro.currentLocale ?? "uk";
const currentYear = new Date().getFullYear();

const TELEGRAM_URL = "https://t.me/psyho_media";
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <!-- Telegram CTA Block -->
  <div class="ft-tg-wrapper">
    <a
      id="footer-telegram-cta"
      href={TELEGRAM_URL}
      class="ft-tg-block"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Перейти в Telegram-канал Людського механізму"
    >
      <p class="ft-tg-overline">Продовження</p>
      <h2 class="ft-tg-title">Механізм продовжується в Telegram</h2>
      <p class="ft-tg-desc">
        Короткі психо-глюки, нові патерни поведінки та фрагменти,
        які не завжди залишаються на сайті.
      </p>
      <span class="ft-tg-btn" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
        </svg>
        Перейти в Telegram
      </span>
    </a>
  </div>

  <!-- Footer bottom bar -->
  <div class="border-border flex flex-col items-center justify-between border-t py-5 sm:flex-row sm:py-4 gap-3">
    <div class="my-1 flex flex-col items-center whitespace-nowrap sm:flex-row text-sm text-muted-foreground">
      <span>Людський механізм &#169; {currentYear}</span>
      <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
      <span>{t.footer.allRightsReserved}</span>
    </div>
    <a
      href={getRelativeLocaleUrl(locale, "search")}
      class="text-muted-foreground hover:text-accent text-sm transition-colors flex items-center gap-1.5"
      aria-label="Пошук по сайту"
    >
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      {t.nav.search}
    </a>
  </div>
</footer>

<style>
  /* ── Wrapper ─────────────────────────────────────────────── */
  .ft-tg-wrapper {
    display: flex;
    justify-content: center;
    padding: 2.5rem 1rem 0;
  }

  /* ── CTA Block ───────────────────────────────────────────── */
  .ft-tg-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    max-width: 34rem;
    padding: 1.75rem 2rem;
    border: 1.5px solid var(--border);
    border-radius: 1rem;
    background: color-mix(in srgb, var(--accent) 4%, var(--background));
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
    margin-bottom: 0.5rem;
  }

  .ft-tg-block:hover {
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
    box-shadow: 0 6px 24px color-mix(in srgb, var(--accent) 10%, transparent);
    transform: translateY(-2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .ft-tg-block {
      transition: border-color 0.15s ease;
    }
    .ft-tg-block:hover {
      transform: none;
      box-shadow: none;
    }
  }

  /* ── Mobile full-width ───────────────────────────────────── */
  @media (max-width: 39.99rem) {
    .ft-tg-wrapper {
      padding: 2rem 0 0;
    }
    .ft-tg-block {
      max-width: 100%;
      border-radius: 0.75rem;
    }
  }

  /* ── Typography ──────────────────────────────────────────── */
  .ft-tg-overline {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.6rem;
  }

  .ft-tg-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: clamp(1.1rem, 2.5vw, 1.3rem);
    font-weight: 700;
    line-height: 1.25;
    color: var(--foreground);
    margin: 0 0 0.6rem;
  }

  .ft-tg-desc {
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--muted-foreground);
    margin: 0 0 1.4rem;
  }

  /* ── Button ──────────────────────────────────────────────── */
  .ft-tg-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.35rem;
    min-height: 44px;
    border-radius: 0.55rem;
    background: var(--accent);
    color: var(--accent-foreground, #fff);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    transition: opacity 0.15s ease;
    width: 100%;
    justify-content: center;
  }

  .ft-tg-block:hover .ft-tg-btn {
    opacity: 0.88;
  }

  @media (min-width: 40rem) {
    .ft-tg-btn {
      width: auto;
      justify-content: flex-start;
    }
  }
</style>

<script>
  /* eslint-disable @typescript-eslint/no-explicit-any */
  declare global {
    interface Window { gtag?: (...args: any[]) => void; }
  }

  function initFooterTelegram() {
    const cta = document.getElementById("footer-telegram-cta");
    if (!cta) return;
    cta.addEventListener("click", () => {
      try {
        if (typeof window.gtag === "function") {
          window.gtag("event", "footer_telegram_click", {
            page_location: window.location.href,
            page_title: document.title,
          });
        }
      } catch { /* ignore */ }
    });
  }

  document.addEventListener("astro:page-load", initFooterTelegram);
  initFooterTelegram();
</script>
