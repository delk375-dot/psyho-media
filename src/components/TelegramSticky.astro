---
/**
 * TelegramSticky.astro
 * ─────────────────────
 * Floating Telegram CTA — shown on article pages after:
 *   • 45 seconds on page, OR
 *   • 60% scroll depth (whichever comes first)
 *
 * Desktop: bottom-left card.
 * Mobile:  slim bottom bar.
 *
 * Dismissal: stored in localStorage for 7 days.
 * GA4 events: telegram_cta_show / telegram_cta_click / telegram_cta_close
 */

const TELEGRAM_LANDING = "/telegram";
---

<div
  id="tg-sticky"
  class="tg-sticky"
  role="complementary"
  aria-label="Telegram-канал Людського механізму"
  aria-hidden="true"
>
  <!-- Desktop card -->
  <div class="tg-card">
    <button
      id="tg-sticky-close"
      class="tg-close"
      type="button"
      aria-label="Закрити"
    >✕</button>

    <p class="tg-eyebrow">↗ Поле</p>

    <p class="tg-title">Telegram — це поле. Сайт — це карта.</p>

    <p class="tg-desc">
      Сигнали, фрагменти, мости — те, що з'являється<br />
      між статтями і не завжди стає ними.
    </p>

    <a
      id="tg-sticky-link"
      href={TELEGRAM_LANDING}
      class="tg-cta"
      aria-label="Читати сигнали в Telegram-каналі"
    >
      Читати сигнали
    </a>
  </div>

  <!-- Mobile bar (separate DOM, same visibility control) -->
  <div class="tg-bar">
    <span class="tg-bar-text">Увійти в поле сигналів</span>
    <a
      href={TELEGRAM_LANDING}
      class="tg-bar-btn"
      id="tg-bar-link"
    >
      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
      </svg>
      Увійти
    </a>
    <button
      id="tg-bar-close"
      class="tg-bar-close"
      type="button"
      aria-label="Закрити"
    >✕</button>
  </div>
</div>

<style>
  /* ── Shared hidden/visible state ─────────────────────────── */
  .tg-sticky {
    pointer-events: none;
  }

  /* ── Desktop card (bottom-left) ─────────────────────────── */
  .tg-card {
    position: fixed;
    bottom: 1.75rem;
    left: 1.5rem;
    z-index: 75;
    width: min(19rem, calc(100vw - 2rem));
    background: var(--background);
    border: 1.5px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.1rem 1.1rem 1rem;
    box-shadow:
      0 8px 32px color-mix(in srgb, var(--foreground) 10%, transparent),
      0 2px 8px color-mix(in srgb, var(--foreground) 5%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    opacity: 0;
    transform: translateY(0.75rem);
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;
    pointer-events: none;
  }

  .tg-sticky.visible .tg-card {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Hide card on mobile */
  @media (max-width: 560px) {
    .tg-card { display: none; }
  }

  /* ── Mobile bottom bar ───────────────────────────────────── */
  .tg-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    /* safe-area for notched Android / iOS devices */
    padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 0.35rem);
    z-index: 75;
    background: var(--background);
    border-top: 1px solid rgba(143, 16, 40, 0.12);
    /* subtle top highlight */
    box-shadow: 0 -1px 0 0 rgba(143, 16, 40, 0.07);
    padding-left: 1rem;
    padding-right: 1rem;
    padding-top: 0.35rem;
    align-items: center;
    gap: 0.75rem;
    min-height: 2.6rem;
    opacity: 0;
    transform: translateY(100%);
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
    pointer-events: none;
  }

  @media (max-width: 560px) {
    .tg-bar { display: flex; }
  }

  .tg-sticky.visible .tg-bar {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .tg-card,
    .tg-bar {
      transition: opacity 0.2s ease;
      transform: none !important;
    }
  }

  /* ── Card internals ─────────────────────────────────────── */
  .tg-close {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: var(--muted-foreground);
    font-size: 0.65rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.14s;
  }

  @media (hover: hover) {
    .tg-close:hover {
      background: color-mix(in srgb, var(--foreground) 8%, transparent);
      color: var(--foreground);
    }
  }

  .tg-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.8;
    margin: 0;
  }

  .tg-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--foreground);
    margin: 0;
  }

  .tg-desc {
    font-size: 0.8rem;
    line-height: 1.55;
    color: var(--muted-foreground);
    margin: 0;
  }

  .tg-cta {
    display: block;
    margin-top: 0.35rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    background: linear-gradient(135deg, #8f1028 0%, #b61f39 100%);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  @media (hover: hover) {
    .tg-cta:hover { opacity: 0.88; }
  }

  /* ── Bar internals ─────────────────────────────────────── */
  .tg-bar-text {
    flex: 1;
    font-size: 0.8rem;
    color: var(--muted-foreground);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tg-bar-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 1rem;
    border-radius: 0.4rem;
    background: linear-gradient(135deg, #8f1028 0%, #b61f39 100%);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.15s;
  }

  @media (hover: hover) {
    .tg-bar-btn:hover { opacity: 0.88; }
  }

  .tg-bar-close {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    border: none;
    background: transparent;
    color: var(--muted-foreground);
    font-size: 0.65rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.14s;
  }

  @media (hover: hover) {
    .tg-bar-close:hover {
      background: color-mix(in srgb, var(--foreground) 8%, transparent);
      color: var(--foreground);
    }
  }
</style>

<script>
  import { trackEvent, trackTelegramClick } from "@/utils/analytics";

  const LS_KEY = "lm_tg_dismissed";
  const COOLDOWN_MS = 7 * 24 * 60 * 60 * 1000; // 7 days
  const SHOW_AFTER_MS = 45_000;                  // 45 seconds
  const SCROLL_THRESHOLD = 0.60;                 // 60% of page

  function fireGA4(event: string) {
    trackEvent(event);
  }

  function initTelegramSticky() {
    const sticky = document.getElementById("tg-sticky");
    if (!sticky) return;

    // Only on article pages
    if (!document.getElementById("article")) return;

    // Check 7-day cooldown
    const dismissed = localStorage.getItem(LS_KEY);
    if (dismissed && Date.now() - parseInt(dismissed, 10) < COOLDOWN_MS) return;

    let shown = false;

    function show() {
      if (shown) return;
      shown = true;
      sticky!.classList.add("visible");
      sticky!.setAttribute("aria-hidden", "false");
      fireGA4("telegram_cta_show");
    }

    function dismiss() {
      sticky!.classList.remove("visible");
      sticky!.setAttribute("aria-hidden", "true");
      localStorage.setItem(LS_KEY, String(Date.now()));
      fireGA4("telegram_cta_close");
    }

    // Timer trigger
    const timer = setTimeout(show, SHOW_AFTER_MS);

    // Scroll trigger
    function onScroll() {
      const scrolled =
        window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
      if (scrolled >= SCROLL_THRESHOLD) {
        clearTimeout(timer);
        show();
        window.removeEventListener("scroll", onScroll);
      }
    }
    window.addEventListener("scroll", onScroll, { passive: true });

    // Close buttons
    document.getElementById("tg-sticky-close")?.addEventListener("click", dismiss);
    document.getElementById("tg-bar-close")?.addEventListener("click", dismiss);

    // GA4 click events
    function onCtaClick() {
      fireGA4("telegram_cta_click"); // legacy — kept for existing GA4 reports
      trackTelegramClick("sticky");
    }
    document.getElementById("tg-sticky-link")?.addEventListener("click", onCtaClick);
    document.getElementById("tg-bar-link")?.addEventListener("click", onCtaClick);
  }

  document.addEventListener("astro:page-load", initTelegramSticky);
  initTelegramSticky();
</script>
