---
/**
 * TelegramSticky.astro
 * ─────────────────────
 * Floating Telegram CTA — shown on article pages after:
 *   • 45 seconds on page, OR
 *   • 60% scroll depth (whichever comes first)
 *
 * Desktop: bottom-left card.
 * Mobile:  slim bottom bar.
 *
 * Dismissal: stored in localStorage for 7 days.
 * GA4 events: telegram_cta_show / telegram_cta_click / telegram_cta_close
 */

const TELEGRAM_URL = "https://t.me/psyho_media";
---

<div
  id="tg-sticky"
  class="tg-sticky"
  role="complementary"
  aria-label="Telegram-канал Людського механізму"
  aria-hidden="true"
>
  <!-- Desktop card -->
  <div class="tg-card">
    <button
      id="tg-sticky-close"
      class="tg-close"
      type="button"
      aria-label="Закрити"
    >✕</button>

    <p class="tg-eyebrow">↗ Telegram</p>

    <p class="tg-title">Механізм продовжується поза сайтом</p>

    <p class="tg-desc">
      Короткі психо-глюки, нові механізми та фрагменти,<br />
      які не потрапляють у статті.
    </p>

    <a
      id="tg-sticky-link"
      href={TELEGRAM_URL}
      class="tg-cta"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Перейти в Telegram-канал Людського механізму"
    >
      Перейти в Telegram
    </a>
  </div>

  <!-- Mobile bar (separate DOM, same visibility control) -->
  <div class="tg-bar">
    <span class="tg-bar-text">Продовжуй у Telegram</span>
    <a
      href={TELEGRAM_URL}
      class="tg-bar-btn"
      target="_blank"
      rel="noopener noreferrer"
      id="tg-bar-link"
    >
      Перейти →
    </a>
    <button
      id="tg-bar-close"
      class="tg-bar-close"
      type="button"
      aria-label="Закрити"
    >✕</button>
  </div>
</div>

<style>
  /* ── Shared hidden/visible state ─────────────────────────── */
  .tg-sticky {
    /* Hidden by default */
    pointer-events: none;
  }

  /* ── Desktop card (bottom-left) ─────────────────────────── */
  .tg-card {
    position: fixed;
    bottom: 1.75rem;
    left: 1.5rem;
    z-index: 75;
    width: min(19rem, calc(100vw - 2rem));
    background: var(--background);
    border: 1.5px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.1rem 1.1rem 1rem;
    box-shadow:
      0 8px 32px color-mix(in srgb, var(--foreground) 10%, transparent),
      0 2px 8px color-mix(in srgb, var(--foreground) 5%, transparent);
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    opacity: 0;
    transform: translateY(0.75rem);
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;
    pointer-events: none;
  }

  .tg-sticky.visible .tg-card {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* Hide card on mobile */
  @media (max-width: 560px) {
    .tg-card { display: none; }
  }

  /* ── Mobile bottom bar ───────────────────────────────────── */
  .tg-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 75;
    height: 3rem;
    background: var(--background);
    border-top: 1px solid var(--border);
    padding: 0 1rem;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
    transform: translateY(100%);
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
    pointer-events: none;
  }

  @media (max-width: 560px) {
    .tg-bar { display: flex; }
  }

  .tg-sticky.visible .tg-bar {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .tg-card,
    .tg-bar {
      transition: opacity 0.2s ease;
      transform: none !important;
    }
  }

  /* ── Card internals ─────────────────────────────────────── */
  .tg-close {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: var(--muted-foreground);
    font-size: 0.65rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.14s;
  }

  .tg-close:hover {
    background: var(--muted);
    color: var(--foreground);
  }

  .tg-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }

  .tg-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--foreground);
    margin: 0;
  }

  .tg-desc {
    font-size: 0.8rem;
    line-height: 1.55;
    color: var(--muted-foreground);
    margin: 0;
  }

  .tg-cta {
    display: block;
    margin-top: 0.35rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    background: var(--accent);
    color: var(--accent-foreground);
    font-size: 0.85rem;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .tg-cta:hover { opacity: 0.88; }

  /* ── Bar internals ─────────────────────────────────────── */
  .tg-bar-text {
    flex: 1;
    font-size: 0.82rem;
    color: var(--muted-foreground);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tg-bar-btn {
    flex-shrink: 0;
    padding: 0.35rem 0.85rem;
    border-radius: 0.4rem;
    background: var(--accent);
    color: var(--accent-foreground);
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .tg-bar-close {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    border: none;
    background: transparent;
    color: var(--muted-foreground);
    font-size: 0.65rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.14s;
  }

  .tg-bar-close:hover {
    background: var(--muted);
    color: var(--foreground);
  }
</style>

<script>
  /* eslint-disable @typescript-eslint/no-explicit-any */
  declare global {
    interface Window { gtag?: (...args: any[]) => void; }
  }

  const LS_KEY = "lm_tg_dismissed";
  const COOLDOWN_MS = 7 * 24 * 60 * 60 * 1000; // 7 days
  const SHOW_AFTER_MS = 45_000;                  // 45 seconds
  const SCROLL_THRESHOLD = 0.60;                 // 60% of page

  function fireGA4(event: string) {
    try {
      if (typeof window.gtag === "function") {
        window.gtag("event", event, {
          page_location: window.location.href,
          page_title: document.title,
        });
      }
    } catch { /* ignore */ }
  }

  function initTelegramSticky() {
    const sticky = document.getElementById("tg-sticky");
    if (!sticky) return;

    // Only on article pages
    if (!document.getElementById("article")) return;

    // Check 7-day cooldown
    const dismissed = localStorage.getItem(LS_KEY);
    if (dismissed && Date.now() - parseInt(dismissed, 10) < COOLDOWN_MS) return;

    let shown = false;

    function show() {
      if (shown) return;
      shown = true;
      sticky!.classList.add("visible");
      sticky!.setAttribute("aria-hidden", "false");
      fireGA4("telegram_cta_show");
    }

    function dismiss() {
      sticky!.classList.remove("visible");
      sticky!.setAttribute("aria-hidden", "true");
      localStorage.setItem(LS_KEY, String(Date.now()));
      fireGA4("telegram_cta_close");
    }

    // Timer trigger
    const timer = setTimeout(show, SHOW_AFTER_MS);

    // Scroll trigger
    function onScroll() {
      const scrolled =
        window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
      if (scrolled >= SCROLL_THRESHOLD) {
        clearTimeout(timer);
        show();
        window.removeEventListener("scroll", onScroll);
      }
    }
    window.addEventListener("scroll", onScroll, { passive: true });

    // Close buttons
    document.getElementById("tg-sticky-close")?.addEventListener("click", dismiss);
    document.getElementById("tg-bar-close")?.addEventListener("click", dismiss);

    // GA4 click events
    function onCtaClick() { fireGA4("telegram_cta_click"); }
    document.getElementById("tg-sticky-link")?.addEventListener("click", onCtaClick);
    document.getElementById("tg-bar-link")?.addEventListener("click", onCtaClick);
  }

  document.addEventListener("astro:page-load", initTelegramSticky);
  initTelegramSticky();
</script>
