---
/**
 * SemanticRecommendations.astro
 * ─────────────────────────────
 * Netflix-style recommendation grid powered by the semantic scoring engine.
 * Shows 3–6 cards with cover image, title, description, reading time, and category.
 *
 * Section title: "Схожі механізми"
 */
import type { CollectionEntry } from "astro:content";
import { getRelatedPosts } from "@/utils/getRelatedPosts";
import { getReadingTime } from "@/utils/readingTime";
import { getPostUrl } from "@/utils/getPostPaths";
import { getGeneratedPostCoverPath } from "@/utils/generatePostCover";
import { getCategoryBySlug } from "@/data/categories";
import { getFormatMeta } from "@/data/contentSystem";

type Props = {
  currentPost: CollectionEntry<"posts">;
  posts: CollectionEntry<"posts">[];
  /** How many recommendations to show. @default 6 */
  limit?: number;
};

const { currentPost, posts, limit = 6 } = Astro.props;

const related = getRelatedPosts(currentPost, posts, limit, {
  useBodySimilarity: true,
  minScore: 1,
});

const locale = Astro.currentLocale;

type CardData = {
  url: string;
  title: string;
  description: string;
  imageUrl: string | undefined;
  categoryTitle: string | undefined;
  formatLabel: string | undefined;
  readingTime: number;
};

const cards: CardData[] = related.map(post => {
  const { title, description, cover, ogImage, category, contentType } = post.data;
  const legacyImage = typeof ogImage === "string" ? ogImage : ogImage?.src;
  const imageUrl = cover ?? legacyImage ?? getGeneratedPostCoverPath(post.id);
  const categoryTitle = getCategoryBySlug(category)?.title;
  const formatMeta = getFormatMeta(contentType);
  const readingTime = getReadingTime(post.body ?? "");
  const url = getPostUrl(post.id, post.filePath, locale);

  return { url, title, description, imageUrl, categoryTitle, formatLabel: formatMeta?.shortLabel, readingTime };
});
---

{
  cards.length > 0 && (
    <section
      class="semantic-recs mt-12 border-t border-border pt-8"
      aria-labelledby="semantic-recs-heading"
    >
      <header class="mb-6">
        <p class="section-kicker text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-1">
          Підібрано для вас
        </p>
        <h2
          id="semantic-recs-heading"
          class="text-xl font-bold"
        >
          Схожі механізми
        </h2>
      </header>

      <ul
        class="semantic-recs-grid"
        role="list"
      >
        {cards.map(card => (
          <li class="semantic-recs-card">
            <a
              href={card.url}
              class="semantic-recs-card-link"
              tabindex="0"
            >
              {/* Cover image */}
              <div class="semantic-recs-card-cover" aria-hidden="true">
                {card.imageUrl ? (
                  <img
                    src={card.imageUrl}
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="semantic-recs-card-placeholder">
                    <span>◆</span>
                  </div>
                )}
              </div>

              {/* Card body */}
              <div class="semantic-recs-card-body">
                {/* Badges row */}
                <div class="semantic-recs-card-badges">
                  {card.categoryTitle && (
                    <span class="format-badge format-badge-soft text-xs">
                      {card.categoryTitle}
                    </span>
                  )}
                  {card.formatLabel && (
                    <span class="format-badge text-xs">
                      {card.formatLabel}
                    </span>
                  )}
                </div>

                {/* Title */}
                <p class="semantic-recs-card-title">
                  {card.title}
                </p>

                {/* Description */}
                <p class="semantic-recs-card-desc">
                  {card.description}
                </p>

                {/* Footer: reading time */}
                <p class="semantic-recs-card-meta">
                  {card.readingTime} хв читання
                </p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}

<style>
  .semantic-recs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 17rem), 1fr));
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .semantic-recs-card {
    display: flex;
  }

  .semantic-recs-card-link {
    display: flex;
    flex-direction: column;
    width: 100%;
    border-radius: 0.625rem;
    border: 1px solid var(--color-border);
    background: var(--color-card, var(--color-background));
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      box-shadow 0.18s ease,
      transform 0.18s ease,
      border-color 0.18s ease;
  }

  .semantic-recs-card-link:hover,
  .semantic-recs-card-link:focus-visible {
    box-shadow: 0 6px 28px color-mix(in srgb, var(--color-accent) 18%, transparent);
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-border));
    outline: none;
  }

  /* Cover */
  .semantic-recs-card-cover {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-muted);
  }

  .semantic-recs-card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .semantic-recs-card-link:hover .semantic-recs-card-cover img {
    transform: scale(1.04);
  }

  .semantic-recs-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    color: var(--color-muted-foreground);
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-muted));
  }

  /* Body */
  .semantic-recs-card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1rem;
    gap: 0.4rem;
  }

  .semantic-recs-card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    min-height: 1.5rem;
  }

  .semantic-recs-card-title {
    font-family: Georgia, "Times New Roman", Times, serif;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-accent);
    /* Clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .semantic-recs-card-desc {
    font-size: 0.83rem;
    line-height: 1.55;
    color: var(--color-muted-foreground);
    flex: 1;
    /* Clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .semantic-recs-card-meta {
    font-size: 0.75rem;
    color: var(--color-muted-foreground);
    opacity: 0.72;
    margin: 0;
    margin-top: 0.25rem;
  }

  /* Mobile: single column on very small screens */
  @media (max-width: 400px) {
    .semantic-recs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
