---
import type { CollectionEntry } from "astro:content";
import Card from "@/components/Card.astro";
import { getRelatedPosts } from "@/utils/getRelatedPosts";

type Props = {
  currentPost: CollectionEntry<"posts">;
  posts: CollectionEntry<"posts">[];
  title?: string;
};

const { currentPost, posts, title = "Пов'язані матеріали" } = Astro.props;
const relatedPosts = getRelatedPosts(currentPost, posts, 4);
---

{
  relatedPosts.length > 0 && (
    <section class="border-border mt-10 border-t pt-8" aria-labelledby="related-articles">
      <h2 id="related-articles" class="text-xl font-semibold">
        {title}
      </h2>
      <ul>
        {relatedPosts.map(post => (
          <Card variant="h3" {...post} />
        ))}
      </ul>
    </section>
  )
}
