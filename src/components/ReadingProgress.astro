---
/**
 * ReadingProgress.astro
 * ─────────────────────
 * Sticky reading progress bar for article pages.
 * - Fixed at top, 2px, accent colour
 * - Only active when #article element exists (post pages)
 * - Fires GA4 events: article_read_25 / 50 / 75 / 100
 * - Respects prefers-reduced-motion
 */
---

<div
  id="reading-progress-bar"
  role="progressbar"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-valuenow="0"
  aria-label="Прогрес читання"
  aria-hidden="true"
></div>

<style>
  #reading-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
    height: 2px;
    width: 0%;
    background: var(--accent);
    transition: width 0.12s linear;
    pointer-events: none;
    transform-origin: left center;
  }

  @media (prefers-reduced-motion: reduce) {
    #reading-progress-bar {
      transition: none;
    }
  }
</style>

<script>
  import { trackArticleDepth } from "@/utils/analytics";

  function initReadingProgress() {
    const bar = document.getElementById("reading-progress-bar");
    const article = document.getElementById("article");

    if (!bar || !article) {
      if (bar) bar.style.display = "none";
      return;
    }

    const progressBar: HTMLElement = bar;
    const articleEl: HTMLElement = article;

    progressBar.style.display = "";

    const fired = new Set<number>();

    function update() {
      const articleRect = articleEl.getBoundingClientRect();
      const articleHeight = articleEl.offsetHeight;
      const scrolledInto = -articleRect.top + window.innerHeight * 0.15;
      const progress = Math.min(1, Math.max(0, scrolledInto / articleHeight));
      const pct = Math.round(progress * 100);

      progressBar.style.width = `${pct}%`;
      progressBar.setAttribute("aria-valuenow", String(pct));

      for (const milestone of [25, 50, 75, 100] as const) {
        if (!fired.has(milestone) && pct >= milestone) {
          fired.add(milestone);
          trackArticleDepth(milestone);
        }
      }
    }

    window.addEventListener("scroll", update, { passive: true });
    update();
  }

  document.addEventListener("astro:page-load", initReadingProgress);
  initReadingProgress();
</script>
