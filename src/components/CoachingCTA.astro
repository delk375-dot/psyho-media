---
import { getServiceCtaBySlug } from "@/data/knowledge";

type Props = {
  variant?: string;
};

const { variant = "executive-coaching" } = Astro.props;
const service = getServiceCtaBySlug(variant);
---

{
  service && (
    <aside class="border-border bg-muted/40 mt-10 border p-5" aria-labelledby="coaching-cta">
      <p class="text-muted-foreground text-sm uppercase tracking-[0.16em]">
        Практичний наступний крок
      </p>
      <h2 id="coaching-cta" class="mt-2 text-xl font-semibold">
        {service.title}
      </h2>
      <p class="mt-3 text-muted-foreground">{service.description}</p>
      <a
        href={`mailto:editorial@example.com?subject=${encodeURIComponent(service.title)}`}
        class="text-accent mt-4 inline-block font-medium underline decoration-dashed underline-offset-4"
      >
        Запросити консультацію
      </a>
    </aside>
  )
}
