---
/**
 * MicrosoftClarity.astro
 *
 * Підключає Microsoft Clarity лише в production (import.meta.env.PROD).
 * У dev-режимі не завантажує жодних скриптів.
 *
 * Щоб активувати — додай env змінну PUBLIC_CLARITY_PROJECT_ID:
 *   - локально: .env  →  PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxxx
 *   - Cloudflare Pages: Settings → Environment variables
 *
 * Якщо змінна відсутня — компонент нічого не рендерить (безпечний fallback).
 */

import { PUBLIC_CLARITY_PROJECT_ID } from "astro:env/client";

const isProd = import.meta.env.PROD;
const projectId = PUBLIC_CLARITY_PROJECT_ID;
---

{isProd && projectId && (
  <!-- Microsoft Clarity: behavioral analytics (heatmaps, session recordings) -->
  <script is:inline define:vars={{ clarityId: projectId }}>
    (function(c, l, a, r, i, t, y) {
      c[a] = c[a] || function() {
        (c[a].q = c[a].q || []).push(arguments);
      };
      t = l.createElement(r);
      t.async = 1;
      t.src = "https://www.clarity.ms/tag/" + i;
      y = l.getElementsByTagName(r)[0];
      y.parentNode.insertBefore(t, y);
    })(window, document, "clarity", "script", clarityId);
  </script>
)}
