---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { getGeneratedPostCoverPath } from "@/utils/generatePostCover";
import { toTransitionName } from "@/utils/toTransitionName";
import Datetime from "./Datetime.astro";
import FormatBadge from "./FormatBadge.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, cover, ogImage, category, contentType, ...props } = data;
const postUrl = getPostUrl(id, filePath, Astro.currentLocale);
const legacyImageSource = typeof ogImage === "string" ? ogImage : ogImage?.src;
const generatedCover = getGeneratedPostCoverPath(id);
const imageSource = cover ?? legacyImageSource ?? generatedCover;
const emotionalLabels: Record<string, string> = {
  relationships: "БЛИЗЬКІСТЬ",
  betrayal: "ЗРАДА",
  manipulation: "КОНТРОЛЬ",
  "toxic-people": "ТОКСИЧНІСТЬ",
  jealousy: "РЕВНОЩІ",
  "sex-attraction": "СЕКС",
  "money-status": "СТАТУС",
  "emotional-dependence": "ЗАЛЕЖНІСТЬ",
  conflicts: "КОНФЛІКТ",
  "self-worth": "СОРОМ",
  family: "РОДИНА",
  "silence-ghosting": "ІГНОР",
};
const visualLabels: Record<string, string> = {
  relationships: "стосунки",
  betrayal: "зради",
  manipulation: "маніпуляції",
  "toxic-people": "токсичність",
  jealousy: "ревнощі",
  "sex-attraction": "потяг",
  "money-status": "гроші",
  "emotional-dependence": "залежність",
  conflicts: "конфлікт",
  "self-worth": "самооцінка",
  family: "родина",
  "silence-ghosting": "ігнор",
  pillar_article: "розбір",
  viral_note: "замітка",
  deep_analysis: "аналіз",
  psychological_fragment: "фрагмент",
  article: "психологія",
};
const visualSymbols: Record<string, string> = {
  relationships: "♡",
  betrayal: "×",
  manipulation: "◌",
  "toxic-people": "!",
  jealousy: "◎",
  "sex-attraction": "≈",
  "money-status": "₴",
  "emotional-dependence": "∞",
  conflicts: "×",
  "self-worth": "◇",
  family: "⌂",
  "silence-ghosting": "…",
  pillar_article: "⚙",
  viral_note: "!",
  deep_analysis: "§",
  psychological_fragment: "…",
  article: "◆",
};
const visualKey = category ?? contentType ?? "article";
const visualLabel = visualLabels[visualKey] ?? visualKey.replaceAll("-", " ");
const visualSymbol = visualSymbols[visualKey] ?? "◆";
const emotionalLabel = category ? emotionalLabels[category] : undefined;
const coverTitle = title
  .replace(/["“”]/g, "")
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 6)
  .join(" ");
---

<li class="post-card border-border border-t py-4 first:border-t-0 sm:py-7">
  <div class="post-card-grid grid grid-cols-[6.9rem_minmax(0,1fr)] gap-4 sm:grid-cols-[10.5rem_minmax(0,1fr)] sm:gap-6 overflow-hidden">
    <a
      href={postUrl}
      class="article-visual focus-visible:no-underline"
      aria-label={title}
    >
      {
        imageSource ? (
          <img src={imageSource} alt="" loading="lazy" decoding="async" />
        ) : (
          <>
            <span class="article-visual-symbol" aria-hidden="true">{visualSymbol}</span>
            <span class="article-visual-title">{coverTitle}</span>
            <span class="article-visual-label">{visualLabel}</span>
          </>
        )
      }
    </a>

    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-2">
        {emotionalLabel && <span class="emotional-label">{emotionalLabel}</span>}
        <FormatBadge contentType={contentType} />
      </div>
      <a
        href={postUrl}
        class:list={[
          "text-accent mt-2 inline-block text-lg font-medium",
          "decoration-dashed underline-offset-4 hover:underline",
          "focus-visible:no-underline focus-visible:underline-offset-0",
        ]}
      >
        <Heading transition:name={toTransitionName(title)}>
          {title}
        </Heading>
      </a>
      <Datetime {...props} />
      <p class="mt-2 leading-7 text-muted-foreground">{description}</p>
    </div>
  </div>
</li>
