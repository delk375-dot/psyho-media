# ── Analytics ────────────────────────────────────────────────────────────────

# Google Search Console site verification token
# Отримай на: https://search.google.com/search-console
PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token_here

# Microsoft Clarity Project ID
# Отримай на: https://clarity.microsoft.com → New Project → Project ID
# Формат: 10 символів, наприклад  ab1cd2ef3g
PUBLIC_CLARITY_PROJECT_ID=your_project_id_here
